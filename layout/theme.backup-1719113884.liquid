  </head>
  <body class="template-{{ template | split: '.' | first }} {% if template == "collection" %}temp_{{ collection.handle }}{% endif %}">
    <noscript
      ><iframe
        src="https://www.googletagmanager.com/ns.html?id=GTM-KV48RTB7"
        height="0"
        width="0"
        style="display:none;visibility:hidden"
      ></iframe
    ></noscript>
    {% if template.name != 'index' %}
      <div class="preloader_nov">
        <div class="nov_load"></div>
      </div>
    {% endif %}
    <a class="in-page-link visually-hidden skip-link" href="#MainContent">
      {{- 'general.accessibility.skip_to_content' | t -}}
    </a>
    <div class="layout_content position-relative">
      <div class="account-list dropdown-menu dropdown-menu-right" id="_desktop_account_list">
        <div class="close_account d-md-flex d-none align-items-center {% if settings.logo_tabbar != blank %}justify-content-between{% else %}justify-content-center{% endif %}">
          {% if settings.logo_tabbar != blank %}
            <a href="/">
              <img
                class="img-fluid logo_tabbar lazyload"
                data-src="{{ settings.logo_tabbar | img_url: '100x' }}"
                alt="{{ settings.logo_tabbar.alt }}"
              >
            </a>
          {% endif %}
          <i class="zmdi zmdi-close"></i>
        </div>
        <div class="nov_sideward_content">
          <div class="account-list-content">
            {% if shop.customer_accounts_enabled %}
              {% if customer %}
                <div>
                  <a
                    class="myaccount"
                    href="{{ shop.secure_url }}/account"
                    rel="nofollow"
                    title="{{ 'layout.customer.account' | t }}"
                  >
                    <span>{{ 'layout.customer.account' | t }}</span>
                  </a>
                </div>
                <div>
                  <a
                    class="logout"
                    href="{{ shop.secure_url }}/account/logout"
                    rel="nofollow"
                    title="{{ 'layout.customer.log_out' | t }}"
                  >
                    <span>{{ 'layout.customer.log_out' | t }}</span>
                  </a>
                </div>
              {% else %}
                <div>
                  <a
                    class="login"
                    href="{{ shop.secure_url }}/account/login"
                    rel="nofollow"
                    title="{{ 'layout.customer.log_in' | t }}"
                  >
                    <span>{{ 'layout.customer.log_in' | t }}</span>
                  </a>
                </div>
                {% if shop.customer_accounts_optional %}
                  <div>
                    <a
                      class="register"
                      href="{{ shop.secure_url }}/account/register"
                      rel="nofollow"
                      title="{{ 'layout.customer.create_account' | t }}"
                    >
                      <span>{{ 'layout.customer.create_account' | t }}</span>
                    </a>
                  </div>
                {% endif %}
              {% endif %}
            {% endif %}
            <div>
              <a
                class="check-out"
                href="{{ shop.secure_url }}/checkout"
                rel="nofollow"
                title="{{ 'layout.customer.checkout' | t }}"
              >
                <span>{{ 'layout.customer.checkout' | t }}</span>
              </a>
            </div>
            {% if settings.wishlist_enable %}
              <div>
                <a
                  class="wishlist"
                  href="/pages/wishlist"
                  rel="nofollow"
                  title="{{ 'layout.customer.wishlists' | t }}"
                  aria-label="View Wishlist"
                >
                  <span>{{ 'layout.customer.wishlists' | t }}</span>
                </a>
              </div>
            {% endif %}
          </div>
        </div>
      </div>
      {% if settings.mini_cart_type == 'canvas' %}
        <div class="cart_canvas_content">
          <div id="_desktop_cart">
            <div class="close_cart d-md-flex d-none align-items-center {% if settings.logo_tabbar != blank %}justify-content-between{% else %}justify-content-center{% endif %}">
              {% if settings.logo_tabbar != blank %}
                <a href="/">
                  <img
                    class="img-fluid logo_tabbar lazyload"
                    data-src="{{ settings.logo_tabbar | img_url: '100x' }}"
                    alt=""
                  >
                </a>
              {% endif %}
              <i class="zmdi zmdi-close"></i>
            </div>
            <div class="dfsdf" id="cart-info"></div>
          </div>
        </div>
      {% endif %}
      {% section 'nov-header' %}
      <main class="main-content" id="MainContent">
        <section class="page-container" id="PageContainer">
          {{ content_for_layout }}
        </section>
      </main>
      {% section 'nov-footer' %}
    </div>
    <div class="canvas-menu drawer-left">
      <div class="canvas-header-box d-flex justify-content-center align-items-center">
        <div class="close-box"><i class="zmdi zmdi-close"></i></div>
      </div>
    </div>
    <div class="canvas-overlay"></div>
    <div class="sidebar-overlay"></div>
    {% include 'nov-formsearch' %}
    {% include 'nov-search-autocomplete' %}
    {% if settings.enable_stickymenu_mobile %}
      {% include 'nov-stickymenu-mobile' %}
    {% endif %}
    {% include 'nov-popup-newsletter' %}
    {% if settings.wishlist_enable %}
      {% include 'nov-popup-wishlist' %}
    {% endif %}
    <div id="_desktop_back_top">
      <div id="back-top">
        <span>
          <i class="zmdi zmdi-chevron-up"></i>
        </span>
      </div>
    </div>
    <div class="link_to_collection_cart_empty d-none">
      <ul class="list-unstyled">
        {% if settings.collec_1_name != blank %}
          <li class="mb-10">
            <a class="btn" href="{{ settings.collec_1 }}"
              ><span>{{ settings.collec_1_name }}</span></a
            >
          </li>
        {% endif %}
        {% if settings.collec_2_name != blank %}
          <li class="mb-10">
            <a class="btn" href="{{ settings.collec_2 }}"
              ><span>{{ settings.collec_2_name }}</span></a
            >
          </li>
        {% endif %}
        {% if settings.collec_3_name != blank %}
          <li class="mb-10">
            <a class="btn" href="{{ settings.collec_3 }}"
              ><span>{{ settings.collec_3_name }}</span></a
            >
          </li>
        {% endif %}
        {% if settings.collec_4_name != blank %}
          <li class="mb-10">
            <a class="btn" href="{{ settings.collec_4 }}"
              ><span>{{ settings.collec_4_name }}</span></a
            >
          </li>
        {% endif %}
        {% if settings.collec_5_name != blank %}
          <li class="mb-10">
            <a class="btn" href="{{ settings.collec_5 }}"
              ><span>{{ settings.collec_5_name }}</span></a
            >
          </li>
        {% endif %}
      </ul>
      <div class="cart-bottom">
        <ul class="sales_points newul">
          <li class="sales_point">
            <span class="icon-and-text">
              <img
                src="https://5203b3-0b.myshopify.com/cdn/shop/files/21-05-2024_4-00-10_PM_220x.jpg"
                alt="Vegan-friendly certification badge"
              >
              <span>Vegan Friendly </span>
            </span>
          </li>
          <li class="sales_point">
            <span class="icon-and-text">
              <img
                src="https://5203b3-0b.myshopify.com/cdn/shop/files/21-05-2024_4-01-45_PM_220x.jpg"
                alt="Cruelty-Free certification badge"
              >
              <span>Cruelty Free</span>
            </span>
          </li>
          <li class="sales_point">
            <span class="icon-and-text">
              <img
                src="https://5203b3-0b.myshopify.com/cdn/shop/files/21-05-2024_4-06-37_PM_220x.jpg"
                alt="Susta-inable certification badge"
              >
              <span>Sustainable</span>
            </span>
          </li>
          <li class="sales_point">
            <span class="icon-and-text">
              <img
                src="https://5203b3-0b.myshopify.com/cdn/shop/files/21-05-2024_4-09-00_PM_220x.jpg"
                alt="Paraben-Free certification badge"
              >
              Paraben Free
            </span>
          </li>
        </ul>
      </div>
    </div>
    <div id="Form_newletter" class="form-vertical modal fade" tabindex="-1" role="dialog" aria-hidden="true">
      <div class="modal-dialog modal-dialog-centered" role="document">
        <div class="modal-content">
          <div class="modal-header position-initial">
            <button type="button" class="close" data-dismiss="modal" aria-label="Close">
              <i class="zmdi zmdi-hc-fw zmdi-close"></i>
            </button>
          </div>
          <div class="modal-body">
            <div class="block_title text-center">
              <div class="title">{{ 'general.newsletter_form.title_popup_soldout' | t }}</div>
              <div class="sub">{{ 'general.newsletter_form.sub_popup_soldout' | t }}</div>
            </div>
            {% form 'customer' %}
              {{ form.errors | default_errors }}
              {% if form.posted_successfully? %}
                <p class="form--success text-center" style="color: #fff;">
                  {{ 'general.newsletter_form.confirmation' | t }}
                </p>
              {% else %}
                <div class="input-group d-block">
                  <input type="hidden" name="contact[tags]" value="newsletter">
                  <input
                    type="email"
                    name="contact[email]"
                    id="Email_newsletter"
                    class="input-group__field newsletter__input text-center"
                    value="{% if customer %}{{ customer.email }}{% endif %}"
                    placeholder="{{ 'general.newsletter_form.email_placeholder_soldout' | t }}"
                  >
                  <button type="submit" class="btn newsletter__submit w-100" name="commit" id="Subscribe_newsletter">
                    <span class="newsletter__submit d-flex align-items-center justify-content-center hover_x">
                      <span>
                        <i class="zmdi zmdi-email"></i>
                        <span>{{ 'general.newsletter_form.noitify_me' | t }}</span>
                      </span>
                      <i class="zmdi zmdi-long-arrow-right"></i>
                    </span>
                  </button>
                </div>
                <div class="checkbox">
                  <label id="myCheck" class="d-inline-flex">
                    <span class="custom-checkbox">
                      <input name="no-view" class="no-view" type="checkbox">
                      <span class="ps-shown-by-js"><i class="zmdi zmdi-check"></i></span>
                    </span>
                    <span id="text">
                      {{ 'general.newsletter_form.note' | t }}
                      <a href="/pages/terms-and-conditions">Terms of Service</a>
                      and
                      <a href="/pages/privacy-policy">Privacy Policy</a>
                    </span>
                  </label>
                </div>
              {% endif %}
            {% endform %}
          </div>
        </div>
      </div>
    </div>
    {% if settings.show_size_chart %}
      <div id="Size_chart" class="form-vertical modal fade" tabindex="-1" role="dialog" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered" role="document">
          <div class="modal-content">
            <div class="modal-header position-initial">
              <button type="button" class="close" data-dismiss="modal" aria-label="Close">
                <i class="zmdi zmdi-hc-fw zmdi-close"></i>
              </button>
            </div>
            <div class="modal-body">
              <div class="single__tabs">
                <div class="block_nav d-flex align-items-center">
                  <ul class="nav nav-tabs">
                    {% if settings.size_image_1 != blank %}
                      <li>
                        <a
                          class="active"
                          href="#womenTabs1"
                          data-toggle="tab"
                          style="color: {{ settings.color_text_tab_1 }}"
                        >
                          {{- settings.text_tab_1 -}}
                        </a>
                      </li>
                    {% endif %}
                    {% if settings.size_image_2 != blank %}
                      <li>
                        <a
                          {% if settings.size_image_1 == blank %}
                            class="active"
                          {% endif %}
                          href="#menTabs2"
                          data-toggle="tab"
                          style="color: {{ settings.color_text_tab_2 }}"
                        >
                          {{- settings.text_tab_2 -}}
                        </a>
                      </li>
                    {% endif %}
                  </ul>
                </div>
                <div class="tab-content">
                  {% if settings.size_image_1 != blank %}
                    <div class="tab-pane active" id="womenTabs1">
                      <div class="block_img">
                        <img src="{{ settings.size_image_1 | img_url: '1170x' }}" alt="img">
                      </div>
                    </div>
                  {% endif %}
                  {% if settings.size_image_2 != blank %}
                    <div class="tab-pane {% if settings.size_image_1 == blank %}active{% endif %}" id="menTabs2">
                      <div class="block_img">
                        <img src="{{ settings.size_image_2 | img_url: '1170x' }}" alt="img">
                      </div>
                    </div>
                  {% endif %}
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    {% endif %}
