<div class="TopContent">
    <div class="container_90">
      <div class="product_tab">
        <div class="container_1320">
          <div class="product-single row">
            <div class="col-lg-6 col-md-12 col-sm-12 col-xs-12">
              <div class="product-single__photos bg_af pro_sticky">
                <div class="proFeaturedImage FeaturedImage_slick">
                  {%- for media in product.media -%}
                    {% case media.media_type %}
                      {% when 'image' %}
                        <div class="item" data-image_src="{{ media | img_url: '1120x' }}">
                          <a class="w-100 d-flex" href="javascript:void(0)" class="product-single__thumbnail">
                            <img class="img-fluid b w-100{% if section.settings.enable_zoom == true %} image-zoom{% endif %}" src="{{ media | img_url: product_image }}" alt="{{ media.alt | escape }}"/>
                          </a>
                        </div>
                      {% when 'external_video' %}
                        <div class="item embed-responsive embed-responsive-16by9{% if forloop.first == true %} act{% endif %}">
                          {{ media | external_video_tag }}
                        </div>
                      {% when 'video' %}
                        <div class="item{% if forloop.first == true %} act{% endif %}">
                          {{ media | video_tag: controls: true, image_size: "1024x" }}
                        </div>
                      {% when 'model' %}
                        <div class="item{% if forloop.first == true %} act{% endif %}">
                          {{ media | model_viewer_tag }}
                        </div>
                      {% else %}
                        <div class="item{% if forloop.first == true %} act{% endif %}">
                          {{ media | media_tag }}
                        </div>
                    {% endcase %}
                  {%- endfor -%}
                </div>
  
                {% if product.images.size > 0 %}
                  <div id="productThumbs" class="mt-10">
                    <div class="thumblist thumb_slick"
                      data-autoplay="false"
                      data-autoplaytimeout="6000"
                      data-loop="false"
                      data-dots="false"
                      data-nav="false"
                      data-items="5"
                      data-items_lg="4"
                      data-items_md="5"
                      data-items_sm="4"
                      data-items_xs="3">
                      {%- for media in product.media -%}
                        <div class="item thumbItem{% if forloop.first == true %} active{% endif %}">
                          <a href="javascript:void(0)" data-image="{{ media.preview_image | img_url: product_image }}" class="product-single__thumbnail">
                            <img class="product-single__thumbnail-image" src="{{ media.preview_image | img_url: '130x130', crop: 'center' }}" alt="{{ media.alt | escape }}">
                            {%- if media.media_type == 'video' or media.media_type =='external_video' -%}
                              <div class="product-single__thumbnail-badge position-absolute">
                                <i class="zmdi zmdi-play-circle-outline"></i>
                              </div>
                            {%- endif -%}
                          </a>
                        </div>
                      {%- endfor -%}
                    </div>
                  </div>
                {% endif %}
              </div>
            </div>
  
            <div class="block_information col-lg-6 col-md-12 col-sm-12 col-xs-12 mt-xs-30">
              <div class="info_content pro_sticky">
                <h1 itemprop="name" class="product-single__title">{{ product.title }}</h1>
                <div class="product-single__meta">
                  {% comment %}
                  {% if product.metafields.judgeme %}
  <div class="judgeme-review-summary">
    {% if product.metafields.judgeme.average_rating and product.metafields.judgeme.review_count %}
      <span class="judgeme-rating">
        Average Rating: {{ product.metafields.judgeme.average_rating }}
      </span>
      <span class="judgeme-review-count">
        ({{ product.metafields.judgeme.review_count }} Reviews)
      </span>
    {% else %}
      <span>No reviews yet.</span>
    {% endif %}
  </div>
{% endif %}
                  {% endcomment %}

                  <div>
                    {% if settings.show_rating %}
                      <div class="group-reviews has-border d-flex align-items-center">
                        <div class="detail-reviews">
                          {% render 'judgeme_widgets', widget_type: 'judgeme_preview_badge', jm_style: '', concierge_install: false, product: product %}
                          <!-- <a href="#ProductSignleReview" class="btn-review__all">{{ 'products.product.review_all_btn' | t }}</a> -->
                        </div>
                      </div>
                    {% endif %}
                    {% assign halved_price = '' %}
                    <div class="gr_pr_rw d-flex align-items-center">
                      <p class="product-single__price product-single__price-{{ section.id }}{% unless current_variant.available %} product-price--sold-out{% endunless %} d-flex align-items-center">
                        {% if current_variant.compare_at_price > current_variant.price %}
                          <span class="visually-hidden">{{ 'products.product.regular_price' | t }}</span>
                          <span class="product-price__price product-price__price-{{ section.id }} product-price__sale product-price__sale--single">
                            <span id="ProductPrice-{{ section.id }}"
                              itemprop="price" content="{{ current_variant.price | divided_by: 100.00 }}" class="productprice price-product-template money mr-10">
                              {{ current_variant.price | money }}
                            </span>
                            <span class="money product-price__sale-label product-price__sale-label-{{ section.id }} d-none">{{ 'products.product.on_sale' | t }}</span>
                          </span>
                          {% assign final_price = current_variant.price | divided_by: 100.00 %}
                          {% assign halved_price = final_price | divided_by: 4 %}
                          <s id="ComparePrice-{{ section.id }}" class="compareprice-product-template">{{ current_variant.compare_at_price | money }}</s>
                        {% else %}
                          <span class="visually-hidden">{{ 'products.product.regular_price' | t }}</span>
                          <span class="product-price__price product-price__price-{{ section.id }}">
                            <span id="ProductPrice-{{ section.id }}"
                              itemprop="price" content="{{ current_variant.price | divided_by: 100.00 }}" class="productprice price-product-template money mr-10">
                              {{ current_variant.price | money }}
                            </span>
                            <span class="money product-price__sale-label product-price__sale-label-{{ section.id }} d-none">{{ 'products.product.on_sale' | t }}</span>
                          </span>
                          {% assign final_price = current_variant.price | divided_by: 100.00 %}
                          {% assign halved_price = final_price | divided_by: 4 %}
                          <s id="ComparePrice-{{ section.id }}" class="compareprice-product-template">{{ current_variant.compare_at_price | money }}</s>
                        {% endif %}
                      </p>
                    </div>
                    <div class="payment_widgets">
                      <div class="afterpay-paragraph">
                        <button class="afterpay-logo brand-afterpay compact-badge type-badge black-on-mint green" aria-label="Afterpay logo - Opens a dialog" title="Afterpay logo - Opens a dialog" data-toggle="modal" data-target="#exampleafterpay">
                          <img loading="lazy" class="afterpay-logo" alt="afterpay" src="//www.culturekings.com.au/cdn/shop/t/3/assets/afterpay_logo.svg" height="30">
                        </button>
                        <span class="afterpay-main-text afterpaytext" data-price="">4x <strong>$ {{ halved_price }}</strong></span>
                      </div>
                      
                      <div class="afterpay-paragraph">
                        <button class="afterpay-logo brand-afterpay compact-badge type-badge black-on-mint pink" aria-label="Afterpay logo - Opens a dialog" title="Afterpay logo - Opens a dialog" data-toggle="modal" data-target="#exampleklarna">
                          <img loading="lazy" class="afterpay-logo" alt="afterpay" src="//www.culturekings.com.au/cdn/shop/t/3/assets/klarna-logo.svg" height="30">
                        </button>
                        <span class="afterpay-main-text afterpaytext" data-price="">4x <strong>$ {{ halved_price }}</strong></span>
                      </div>
  
                      <div class="afterpay-paragraph">
                        <button class="afterpay-logo brand-afterpay compact-badge type-badge black-on-mint white" aria-label="Afterpay logo - Opens a dialog" title="Afterpay logo - Opens a dialog">
                          <img loading="lazy" class="afterpay-logo" alt="afterpay" src="https://www.culturekings.com.au/cdn/shop/t/3/assets/logo-zippay.svg" height="30">
                        </button>
                        <span class="afterpay-main-text afterpaytext" data-price="">From <strong>$10</strong></span>
                      </div>
                    </div>
                    {% if section.settings.show_des %}
                      <div class="product-single__shortdes" itemprop="description">
                        {% comment %}{{ product.description | strip_html | truncatewords: 30}} {% endcomment %}
                        {{ product.description }}
                      </div>
                    {% endif %}
                    {% if section.settings.show_available %}
                      {% unless product.available %}
                        <div class="available_product d-flex align-items-center">
                          <div class="available_name control-label">
                            {{ "products.product.available" | t }}
                          </div>
                          <span class="product__available sold-out">
                            <span>{{ "products.product.sold_out" | t }}</span>
                            <i class="fa fa-ban" aria-hidden="true"></i>
                          </span>
                        </div>
                      {% else %}
                        <div class="available_product d-flex align-items-center">
                          <div class="available_name control-label">
                            {{ "products.product.available" | t }}
                          </div>
                          <span class="product__available in-stock">
                            <span>{{ "products.product.in_stock" | t }}</span>
                            <i class="fa fa-check-square-o" aria-hidden="true"></i>
                          </span>
                        </div>
                      {% endunless %}
                    {% endif %}
                    <div class="group-single__items has-border">
                      {% if section.settings.show_tags %}
                        <p itemprop="tags" class="product-single__tags d-flex">
                          <span class="label control-label">{{ 'products.product.lable_tags' | t }}:</span>
                          <span class="list-tags">
                            {% for tag in product.tags %}
                              {% if tag != 'upsell' %}
                                {% capture url %}/collections/all/{{ tag | handle }}{% endcapture %}
                                {% if forloop.last == true %}
                                  {{ tag | link_to: url }}
                                {% else %}
                                  {{ tag | link_to: url }},
                                {% endif %}
                              {% endif %}
                            {% endfor %}
                          </span>
                        </p>
                      {% endif %}
                      {% if section.settings.show_sku %}
                        <p itemprop="sku" class="product-single__sku">
                          <span class="label control-label">{{ 'products.product.lable_sku' | t }}:</span>
                          <span class="label-sku variant-sku">{{ current_variant.sku }}</span>
                        </p>
                      {% endif %}
                      {% if section.settings.show_categories %}
                        <p itemprop="cat" class="product-single__cat d-flex">
                          <span class="label control-label">{{ 'products.product.lable_category' | t }}:</span>
                          <span class="label-cate">
                            {% for collection in product.collections %}
                              {% if forloop.last == true %}
                                <a href="{{ collection.url }}" title="{{ collection.title }}">{{ collection.title }}</a>
                              {% else %}
                                <a href="{{ collection.url }}" title="{{ collection.title }}">{{ collection.title }},</a>
                              {% endif %}
                            {% endfor %}
                          </span>
                        </p>
                      {% endif %}
                      {% if section.settings.show_vendor %}
                      <p itemprop="brand" class="product-single__vendor">
                        <span class="label control-label">{{ 'products.product.lable_vendor' | t }}:</span>
                        <span class="label-vendor">
                        {{ product.vendor }}
                        </span>
                      </p>
                    {% endif %}
                    </div>
                  </div>
                </div>
                <form action="/cart/add" method="post" enctype="multipart/form-data" class="product-form product-form-{{ section.id }}" data-section="{{ section.id }}">
                  <div class="items_var_size d-lg-flex d-md-block variantsection sss">
                    {% if variantCount > 1 %}
                    <div class="selectorVariants prd_dtai">
                    {% endif %}
                      {% if section.settings.product_swatch_enable %}
                        {% if variantCount > 1 %}
                          {% for option in product.options %}
                            {% include 'nov-swatch' with option %}
                          {% endfor %}
                        {% endif %}
                      {% endif %}
  
                      <select name="id" id="productSelect" data-section="{{ section.id }}" {% if section.settings.product_swatch_enable %}class="enable_swatch hide"{% endif %}>
                        {% for variant in product.variants %}
                          {% if variant.available %}
                            <option value="{{ variant.id }}" data-qty="{{ variant.inventory_quantity }}"{% if variant == product.selected_or_first_available_variant %} selected="selected"{% endif %}>{{ variant.title }}</option>
                          {% else %}
                            <option value="{{ variant.id }}" data-qty="{{ variant.inventory_quantity }}" disabled="disabled">{{ variant.title }} - {{ 'products.product.sold_out' | t }}</option>
                          {% endif %}
                        {% endfor %}
                      </select>
                    {% if variantCount > 1 %}
                    </div>
                    {% endif %}
                    {% if variantCount > 1 %}
                      {% if settings.show_size_chart %}
                        <div class="size_chart d-flex align-items-end" data-toggle="modal" data-target="#Size_chart">
                          <i class="zmdi zmdi-ruler"></i>
                          <span>{{ 'sections.product_deals.size_chart' | t }}</span>
                        </div>
                      {% endif %}
                    {% endif %}
                  </div>
                  {% unless current_variant.available == false %}
                    {% if section.settings.show_notes %}
                      <div class="line-item-property__field">
                        <label class="label control-label" for="notes">{{ 'products.product.notes' | t }}</label>
                        <textarea rows="5" id="notes" name="properties[Notes]" placeholder="Write here your notes for the order" class="mb-0"></textarea>
                      </div>
                    {% endif %}
                  {% endunless %}
                  <div class="group-quantity">
                    {% unless current_variant.available == false %}
                      {% if section.settings.show_quantity_selector %}
                        <span class="control-label">{{ 'products.product.quantity' | t }}</span>
                      {% endif %}
                    {% endunless %}
                    {% unless current_variant.available == false %}
                    <div class="product-form__item product-form__item--quantity align-items-center mb-10">
                    {% endunless %}
                      {% unless current_variant.available == false %}
                        {% if section.settings.show_quantity_selector %}
                          <label for="Quantity" class="quantity-selector"></label>
                          <div class="quick_view_qty mr-10">
                            <a href="javascript:void(0);" class="quick_view-qty quick_view-qty-minus">-</a>
                            <input type="number" id="Quantity" name="quantity" value="1" min="1" max="{{ current_variant.inventory_quantity }}" step="1" class="quantity-selector product-form__input" pattern="[0-9]*">
                            <a href="javascript:void(0);" class="quick_view-qty quick_view-qty-plus">+</a>
                          </div>
                        {% endif %}
                      {% endunless %}
                      {% unless current_variant.available %}
                        <div class="btn btnsold_out sold_out d-flex align-items-center justify-content-center" data-toggle="modal" data-target="#Form_newletter">
                          <span class="hover_x note align-items-center w-100">
                            
                              <i class="zmdi zmdi-email"></i>
                              <span>{{ "products.product.notify_me" | t }}</span>
                            
                            <i class="zmdi zmdi-long-arrow-right"></i>
                          </span>
                          <span class="loading d-none"><i class="fa fa-spin"></i></span>
                        </div>
                      {% else %}
                        <div class="product-form__item product-form__item--submit">
                          <button data-handle="{{ product.handle }}" type="submit" name="add" id="AddToCart" {% unless current_variant.available %}disabled="disabled"{% endunless %} class="hover_x btnAddToCart btn product-form__cart-submit{% if product.options.size == 1 and product.variants[0].title == 'Default Title' %} product-form__cart-submit--small{% endif %}">
                            {% if current_variant.inventory_policy == 'continue' and current_variant.inventory_quantity < 1 %}
                              <span id="AddToCartText" class="position-relative">{{ 'products.product.pre_order' | t }}</span>
                            {% else %}
                              <span id="AddToCartText">{{ 'products.product.add_to_cart' | t }}</span>
                            {% endif %}
                            <i class="zmdi zmdi-long-arrow-right"></i>
                          </button>
                        </div>
                      {% endunless %}
                    {% unless current_variant.available == false %}
                    </div>
                    {% endunless %}
                    {% unless current_variant.available == false %}
                      <div class="product_option_sub">
                        {% if settings.payment_button_enable %}
                          <div class="product-form__item product-form__item--checkout">
                            {% form 'product', product, class:form_classes, novalidate: 'novalidate', data-product-form: '' %}
                            {{ form | payment_button }}
                            {% endform %}
                          </div>
                        {% endif %}
                      </div>
                    {% endunless %}
                    {% if section.settings.show_payments %}
                      <div class="product-page-info__payments product-page-info__field d-flex flex-column align-items-start mt-40 mb-10">
                        <label class="mb-6 text-uppercase" style="{% if section.settings.color_title_payments != blank %}color: {{ section.settings.color_title_payments }};{% endif %}{% if section.settings.size_title != blank %}font-size: {{ section.settings.size_title }}"{% endif %}>{{ section.settings.title_payments }}</label>
                        <div class="payments overflow-hidden">
                          <img class="lazyload" data-src="{{ section.settings.payments | img_url: '250x' }}" alt="Payments">
                        </div>
                      </div>
                    {% endif %}
                  </div>
                </form>
                {% if settings.wishlist_enable %}
                  <div class="productWishList">
                    <a class="wishlist btnProductWishlist d-flex align-items-center" data-icon-wishlist href="#" data-product-handle="{{ product.handle }}" data-id="{{ product.id | json }}">
                      <i class="zmdi zmdi-favorite-outline"></i>
                      <i class="zmdi zmdi-favorite"></i>
                      <span class="wishlist-text">{{ 'products.product.wishlist' | t }}</span>
                    </a>
                  </div>
                {% endif %}
                {% if section.settings.show_share %}
                  <div class="productbuttons d-flex align-items-center">
                    <span class="label control-label"><i class="zmdi zmdi-share"></i>{{ 'products.product.lable_share' | t }}</span>
                    <span class="items_share d-flex align-items-center">
                      {% if settings.share_facebook %}
                        <a target="_blank" href="//www.facebook.com/sharer.php?u={{ shop.url | append: product.url }}" class="btn--share share-facebook" title="{{ 'general.social.alt_text.share_on_facebook' | t }}">
                          <i class="zmdi zmdi-facebook"></i>
                          <span class="share-title" aria-hidden="true">{{ 'general.social.share_on_facebook' | t }}</span>
                        </a>
                      {% endif %}
  
                      {% if settings.share_twitter %}
                        <a target="_blank" href="//twitter.com/share?text={{ article.title | url_param_escape }}&amp;url={{ shop.url | append: product.url }}" class="btn--share share-twitter" title="{{ 'general.social.alt_text.share_on_twitter' | t }}">
                          <i class="fa fa-twitter" aria-hidden="true"></i>
                          <span class="share-title" aria-hidden="true">{{ 'general.social.share_on_twitter' | t }}</span>
                        </a>
                      {% endif %}
  
                      {% if settings.share_pinterest %}
                        <a target="_blank" href="//pinterest.com/pin/create/button/?url={{ shop.url | append: product.url }}&amp;media={{ product.featured_image | img_url: '1024x1024' }}" class="btn--share share-pinterest" title="{{ 'general.social.alt_text.share_on_pinterest' | t }}">
                          <i class="fa fa-pinterest" aria-hidden="true"></i>
                          <span class="share-title" aria-hidden="true">{{ 'general.social.share_on_pinterest' | t }}</span>
                        </a>
                      {% endif %}
                  </div>
                {% endif %}
                <div class="shiping">
                  {% if section.settings.time != blank %}
                    <div class="shiping_time d-flex align-items-center" style="{% if section.settings.color_time != blank %}color: {{ section.settings.color_time }};{% endif %}{% if section.settings.size_time != blank %}font-size: {{ section.settings.size_time }}"{% endif %}>
                      <i class="zmdi zmdi-time"></i>
                      <span>{{ section.settings.time | nofilter }}</span>
                    </div>
                  {% endif %}
                  {% if section.settings.truck != blank %}
                    <div class="shiping_truck d-flex align-items-center" style="{% if section.settings.color_truck != blank %}color: {{ section.settings.color_truck }};{% endif %}{% if section.settings.size_truck != blank %}font-size: {{ section.settings.size_truck }}"{% endif %}>
                      <i class="zmdi zmdi-truck"></i>
                      <span>{{ section.settings.truck | nofilter }}</span>
                    </div>
                  {% endif %}
                  </div>
                  {% for block in section.blocks %}
                    {% if block.type == 'block_icons' %}
                        <div class="section_icon">
                            {% if  block.settings.custom_icon1 != blank %}
                                <div class="icons"><img src="{{ block.settings.custom_icon1 | img_url: '220x' }}"></div>
                            {% endif %}
                            {% if  block.settings.custom_icon2 != blank %}
                                <div class="icons"><img src="{{ block.settings.custom_icon2 | img_url: '220x' }}"></div>
                            {% endif %}
                            {% if  block.settings.custom_icon3 != blank %}
                                <div class="icons"><img src="{{ block.settings.custom_icon3 | img_url: '220x' }}"></div>
                            {% endif %}
                            {% if  block.settings.custom_icon4 != blank %}
                                <div class="icons"><img src="{{ block.settings.custom_icon4 | img_url: '220x' }}"></div>
                            {% endif %}
                            {% if  block.settings.custom_icon5 != blank %}
                                <div class="icons"><img src="{{ block.settings.custom_icon5 | img_url: '220x' }}"></div>
                            {% endif %}
                        </div>
                    {% endif %}
                {% endfor %}
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
    <div class="single__tab" {% if section.settings.background_color != blank %}style="background-color: {{ section.settings.background_color }};"{% endif %}>
      <div class="container_1320">
        <div class="product-single__tabs wow fadeInUp animated">
          <div class="block_nav">
            <ul class="nav nav-tabs">
              {% if section.settings.show_description %}
                <li><a class="active" href="#proTabs1" data-toggle="tab">{{ 'products.product.tabdes' | t }}</a></li>
              {% endif %}
              {% if settings.show_rating %}
                <li><a class="" href="#proTabs2" data-toggle="tab">Reviews</a></li>
              {% endif %}
              
              {% for block in section.blocks %}
                {% if block.type == 'block_text' %}
                  <li><a href="#tabCustom-{{ forloop.index }}" data-toggle="tab">{{ block.settings.custom_title }}</a></li>
                {% endif %}
                {% if block.type == 'block_img' %}
                  <li><a href="#tabCustom-{{ forloop.index }}" data-toggle="tab">{{ block.settings.custom_title }}</a></li>
                {% endif %}
                {% if block.type == 'block_video' %}
                  <li><a href="#tabCustom-{{ forloop.index }}" data-toggle="tab">{{ block.settings.custom_title }}</a></li>
                {% endif %}
              {% endfor %}
            </ul>
          </div>
          <div class="tab-content">
            {% if section.settings.show_description %}
            <div class="tab-pane active" id="proTabs1">{{ product.description }}</div>
            {% endif %}
  
            {% if settings.show_rating %}
                <div id="proTabs2" class="tab-pane">
                  {% render 'judgeme_widgets', widget_type: 'judgeme_review_widget', concierge_install: false, product: product %}
                </div>
            {% endif %}
  
            
            {% if section.settings.show_review or settings.show_rating %}
              <div class="tab-pane" id="tabreview">
                <div id="shopify-product-reviews" data-id="{{product.id}}">{{ product.metafields.spr.reviews }}</div>
              </div>
            {% endif %}
            {% for block in section.blocks %}
              {% if block.type == 'block_text' %}
                <div class="tab-pane" id="tabCustom-{{ forloop.index }}">
                  <div class="product-description">{{ block.settings.custom_content }}</div>
                </div>
              {% endif %}
              {% if block.type == 'block_img' %}
                <div class="tab-pane" id="tabCustom-{{ forloop.index }}">
                  <div class="block_img mt-20" data-toggle="modal" data-target="#ImageModal{{ forloop.index }}">
                    <img src="{{ block.settings.custom_content | img_url: '1290x' }}" alt="img">
                  </div>
                </div>
              {% endif %}
  
              {% if block.type == 'block_video' %}
                <div class="tab-pane" id="tabCustom-{{ forloop.index }}">
                  <div class="embed-responsive embed-responsive-16by9">
                    <iframe class="embed-responsive-item" src="{%- if block.settings.video_url.type == 'youtube' -%}https://www.youtube.com/embed/{{ block.settings.video_url.id }}{%- else -%}https://player.vimeo.com/video/{{ block.settings.video_url.id }}{%- endif -%}" allow="autoplay; encrypted-media" allowfullscreen></iframe>
                  </div>
                </div>
              {% endif %}
            {% endfor %}
          </div>
        </div>
      </div>
    </div>
  </div>
  <div class="modal" id="exampleafterpay" tabindex="-1" role="dialog" aria-labelledby="exampleModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered" role="document">
      <div class="modal-content">
        <div class="modal-header">
          <button type="button" class="close" data-dismiss="modal" aria-label="Close">
            <span aria-hidden="true">×</span>
          </button>
        </div>
