<script>
  var theme = {
    strings: {
      select_options: {{ 'products.product.select_options' | t | json }},
      addToCart: {{ 'products.product.add_to_cart' | t | json }},
      preorder: {{ 'products.product.pre_order' | t | json }},
      soldOut: {{ 'products.product.sold_out' | t | json }},
      notify_me: {{ 'products.product.notify_me' | t | json }},
      unavailable: {{ 'products.product.unavailable' | t | json }},
      showMore: {{ 'general.filters.show_more' | t | json }},
      showLess: {{ 'general.filters.show_less' | t | json }},
      addressError: {{ 'sections.map.address_error' | t | json }},
      addressNoResults: {{ 'sections.map.address_no_results' | t | json }},
      addressQueryLimit: {{ 'sections.map.address_query_limit_html' | t | json }},
      authError: {{ 'sections.map.auth_error_html' | t | json }},
      total: {{ 'general.popup_cart.total' | t | json }},
      spend: {{ 'cart.general.spend' | t | json }},
      content_threshold: {{ 'cart.general.content_threshold' | t | json }},
      spend__html: {{ 'cart.general.spend__html' | t | json }},
      check_out: {{ 'cart.general.checkout' | t | json }},
      remove: {{ 'wishlist.wishlist.wishlist_remove' | t | json }},
      remove_wishlist: {{ 'wishlist.wishlist.remove_wishlist' | t | json }},
      add_to_wishlist: {{ 'wishlist.wishlist.add_to_wish_list' | t | json }},
      added_to_wishlist: {{ 'wishlist.wishlist.add_to_wish_list' | t | json }},
      view_cart: {{ 'cart.general.view_cart' | t | json }},
      cart_empty: {{ 'cart.general.empty' | t | json }},
      continue_shopping: {{ 'cart.general.continue_shopping' | t | json }},
      shippingCalcSubmitButton: {{ 'cart.mini_canvas.calculate_shipping' | t | json }},
      shippingCalcSubmitButtonDisabled: {{ 'cart.mini_canvas.calculating' | t | json }},
      {% if customer %}shippingCalcCustomerIsLoggedIn: true,{% endif %}
      shippingCalcMoneyFormat: {{ shop.money_with_currency_format | json }},
      cart_message_html: {{ 'cart.general.cart_message_html' | t | json }},
      results_all: {{ 'general.search.results_all' | t | json }},
      countdown_hours:           {{ 'countdown.hours' | t | json }},
      countdown_mins:            {{ 'countdown.mins' | t | json }},
      countdown_secs:            {{ 'countdown.secs' | t | json }},
      date_formats_d:            {{ 'countdown.formats.d' | t | json }},
      date_formats_h:            {{ 'countdown.formats.h' | t | json }},
      date_formats_m:            {{ 'countdown.formats.m' | t | json }},
      date_formats_s:            {{ 'countdown.formats.s' | t | json }}
    },
    moneyFormat: {{ shop.money_format | json }},
    moneyFormatnojson: {{ shop.money_format | json }},
    freeshipping_value: {{ settings.free_shipping }},
    show_free_shipping: {{ settings.freeshipping_enable }}
  }
  window.variantStrings = {
    addToCart: `{{ 'products.product.add_to_cart' | t }}`,
    soldOut: `{{ 'products.product.sold_out' | t }}`,
    unavailable: `{{ 'products.product.unavailable' | t }}`,
    notify_me: `{{ 'products.product.notify_me' | t }}`,
    preorder: `{{ 'products.product.pre_order' | t }}`,
  }
  window.file_url = '{{""|file_url}}';
  window.asset_url = '{{"hh"|asset_url|remove: "hh"}}';
  window.sidebar_multichoise = true;
  document.documentElement.className = document.documentElement.className.replace('no-js', 'js');
  window.router = "";
  var vinovathemes = {
    main_info: {
      shop: '{{ shop.permanent_domain }}',
      domain: '{{ shop.domain }}',
      lic: '{{ settings.license | strip_newlines | whitespace }}',
      status: '{{ settings.purchase_action }}',
    }
  }
</script>
