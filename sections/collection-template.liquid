
{%- assign limit = section.settings.products_per_page -%}
{% if template == "collection.leftsidebar" %}
  {% assign viewtype = "leftsidebar" %}
{% elsif template == "collection.rightsidebar" %}
  {% assign viewtype = 'rightsidebar' %}
{% elsif template == "collection.full_width" %}
  {% assign viewtype = 'full_width' %}
{% elsif template == "collection.canvas" %}
  {% assign viewtype = 'canvas' %}
{% else %}
  {% if settings.type_sidebar == 'sidebar_left' %}
    {% assign viewtype = 'leftsidebar' %}
  {% elsif settings.type_sidebar == 'sidebar_right' %}
    {% assign viewtype = 'rightsidebar' %}
  {% elsif settings.type_sidebar == 'full_width' %}
    {% assign viewtype = 'full_width' %}
  {% else %}
    {% assign viewtype = 'canvas' %}
  {% endif %}
{% endif %}
{% include 'nov-breadcrumb' %}
<div id="main-collection-filters" data-id="{{ section.id }}">
  <div class="container_90 {% if settings.breadcrumbs_enable %} collection_mt{% endif %}">
    <div class="collection-{{ viewtype }}">
    {% if viewtype != 'full_width' %}
      <div class="container_1320">
    {% endif %}
      {% unless template == 'collection.offer-collection' %}
      <div class="d-flex align-items-center pt-40 pb-20 pt-lg-40 pb-lg-30 pt-xs-30 justify-content-between w-100">
        <div class="filter_button{% if viewtype != 'canvas' %} d-lg-none{% endif %}">
          <i class="zmdi zmdi-tune"></i>
          <span class="d-none d-md-inline-block">{{ 'collections.filters.button' | t }}</span>
        </div>

        <div class="bl_right d-flex align-items-center">
          <div class="gridlist-toggle order-2 order-md-0">
            {% comment %}
            {% if viewtype == 'canvas' %}
              <a href="#" id="grid-4" title="Grid View 4" data-type="grid-4" class="active d-none d-lg-block"><i class="zmdi zmdi-view-comfy"></i></a>
            {% endif %}
            {% endcomment %}
              <a href="#" id="grid-4" title="Grid View 4" data-type="grid-4" class="active d-none d-lg-block"><i class="zmdi zmdi-view-comfy"></i></a>
              <a href="#" id="grid-3" title="Grid View 3" data-type="grid-3" class="{% if viewtype != 'canvas' %}active{% endif %}"><i class="zmdi zmdi-view-week"></i></a>
              <a href="#" id="grid-2" title="Grid View 2" data-type="grid-2"><i class="zmdi zmdi-pause"></i></a>
              <a href="#" id="list" title="List View" data-type="list"><i class="zmdi zmdi-view-headline"></i></a>
          </div>
          {% if section.settings.sort_enable %}
            <div class="" data-sortby-filter>
              <div class="dropdown-toggle d-flex align-items-center pb-5 pb-xs-0" data-toggle="dropdown" aria-haspopup="true" aria-expanded="false">
                <span class="sort-by__label"></span>
                <i class="zmdi zmdi-caret-down"></i>
              </div>
              <div class="dropdown-menu dropdown-menu-right text-right">
                {%- for option in collection.sort_options -%}
                  {% if option.value == 'best-selling' %}
                      <div value="{{ option.value | escape }}" data-sortby-item>Top sellers</div>
                  {% else %}
                      <div value="{{ option.value | escape }}" data-sortby-item>{{ option.name | escape }}</div>
                  {% endif %}
                {%- endfor -%}
              </div>

            </div>
          {% endif %}
        </div>
      </div>
      {% endunless %}
      {% unless template == 'collection.offer-collection' %}
      <div class="pageTitle pb-20"><h1>{{ collection.title }}</h1></div>
      {% endunless %}
      <div class="row">
        {% if section.settings.banner != blank %}
          <div class="col-12 mb-60">
            <div class="collection_banner">
              <img class="lazyload" data-src="{{ section.settings.banner | img_url: '1920x' }}" alt="{{ section.settings.banner.alt }}">
            </div>
          </div>
        {% endif %}
        <div class="col-lg-3 sidebar-filter{% if viewtype == 'rightsidebar' %} order-0 order-md-2{% endif %}">
          {% include 'collection-filters', results: collection %}
        </div>
        <div class="{% if viewtype == 'canvas' %}col-lg-12 col-md-12{% else %}col-lg-9{% endif %}">
          
          {% if template == 'collection.offer-collection' %}
          <div class="d-flex align-items-center pb-30 justify-content-between w-100 offer-top-bar" style="gap: 15px;">
            <div class="offer-search-container flex-grow-1" style="min-width: 250px;">
              <form action="/search" method="get" class="search-header-offer" style="position:relative; width: 100%; border: 1px solid #dcdcdc; border-radius: 30px; overflow:hidden; display:flex; background: #fff; align-items: center; padding: 2px 2px 2px 20px;">
                <input type="hidden" name="type" value="product">
                <input type="text" name="q" placeholder="Notes, Scent family, Style, Code" style="flex: 1; border: none; padding: 8px 0; outline: none; background: transparent; font-size: 13px; color: #555;">
                <button type="submit" style="background: #c3a887; border: none; padding: 0; width: 32px; height: 32px; border-radius: 50%; display: flex; align-items: center; justify-content: center; cursor: pointer; color: #fff; font-size: 16px; margin-left: 5px;">
                  <i class="zmdi zmdi-search"></i>
                </button>
              </form>
            </div>

            <div class="bl_right d-flex align-items-center justify-content-end" style="gap: 15px; flex-shrink: 0;">
              <div class="gridlist-toggle d-flex">
                  <a href="#" id="grid-4" title="Grid View 4" data-type="grid-4" class="active d-none d-lg-block"><i class="zmdi zmdi-view-comfy"></i></a>
                  <a href="#" id="grid-3" title="Grid View 3" data-type="grid-3" class="{% if viewtype != 'canvas' %}active{% endif %}"><i class="zmdi zmdi-view-week"></i></a>
                  <a href="#" id="grid-2" title="Grid View 2" data-type="grid-2"><i class="zmdi zmdi-pause"></i></a>
                  <a href="#" id="list" title="List View" data-type="list"><i class="zmdi zmdi-view-headline"></i></a>
              </div>
              
              {% if section.settings.sort_enable %}
                <div class="" data-sortby-filter>
                  <div class="dropdown-toggle d-flex align-items-center" data-toggle="dropdown" aria-haspopup="true" aria-expanded="false" style="border: 1px solid #ccc; padding: 5px 15px; border-radius: 4px; background: #fff; cursor: pointer;">
                    <span class="sort-by__label" style="font-size: 12px; font-weight: 600; text-transform: uppercase;"></span>
                    <i class="zmdi zmdi-caret-down" style="margin-left: 10px;"></i>
                  </div>
                  <div class="dropdown-menu dropdown-menu-right text-right">
                    {%- for option in collection.sort_options -%}
                      {% if option.value == 'best-selling' %}
                          <div value="{{ option.value | escape }}" data-sortby-item>Top sellers</div>
                      {% else %}
                          <div value="{{ option.value | escape }}" data-sortby-item>{{ option.name | escape }}</div>
                      {% endif %}
                    {%- endfor -%}
                  </div>
                </div>
              {% endif %}
            </div>
          </div>
          {% endif %}

          <div class="colletTemplate collection__product-content collection--product-{{ viewtype }}" {% if viewtype == 'canvas' %}data-grid="grid-4"{% else %}data-grid="grid-3"{% endif %}>
            <div id="ProductGridContainer">
              {%- paginate collection.products by section.settings.products_per_page -%} 
                {%- if collection.products.size == 0 -%}
                  <div id="product-grid" data-id="{{ section.id }}" class="text-center pt-60">
                    <h2 class="mb-20">{{ 'collections.filters.empty' | t }}</h2>
                    <h4>{{ 'collections.filters.use_fewer_filters_html' | t: link: collection.url }}</h4>
                  </div>
                {%- else -%}
                  <div id="product-grid" data-id="{{ section.id }}" class="row grid--view-items spacing-md-15">
                    {%- for product in collection.products -%}

{% comment %}                  
location based out of stock and producr hide    
data-product-handle="{{ product.handle }}"
{% endif %}


{% assign location_id = detected_location_id %}
{% assign stock_key = 'custom.stock_' | append: location_id %}
{% assign location_stock = product.metafields.custom[stock_key] | default: 0 %}

{% if location_stock > 0 %}
{% endcomment %} 


                      <div class="product--item col">
                        <div class="item-product{% unless product.available %} product-price--sold-out{% endunless %}">
                          {% assign variantCount = product.variants | size %}
                          <div class="thumbnail-container{% if product.images.size > 2 %} has-multiimage{% endif %}{% if settings.show_variant_color and variantCount > 1 %} has_variants{% endif %}">
                            <a href="{{ product.url }}">
                              <div class="materialtype">
                                {% assign checkvariant = "" %}
                                {% for variant in product.variants %}
                                  {% for option in variant.options %}
                                    {% if product.options[forloop.index0] == 'Material' %}
                                      {% if checkvariant == blank %}
                                        <p class="{{ variant.title }}">
                                          {{ variant.title }}
                                          {% assign checkvariant = variant.title %}
                                        </p> 
                                      {% endif %}
                                    {% endif %}
                                    {% endfor %}

                                    {% if product.metafields.custom.scent_material != blank %}
                                      {% assign checkvariant = variant.title %}
                                      <p class="{{ product.metafields.custom.scent_material.value }}">
                                        {{ product.metafields.custom.scent_material.value }}
                                        {% assign checkvariant = product.metafields.custom.scent_material.value %}
                                      </p> 
                                    {% endif %}
                                  
                                {% endfor %}
                              </div>
                              <div class="respone_image" style="padding-top:{{ 1 | divided_by: product.featured_image.aspect_ratio | times: 100}}%">
                                {% assign img_url = product.featured_image | img_url: '1x1' | replace: '_1x1.', '_{width}x.' %}
                                <noscript>
                                  <img class="img-fluid product__thumbnail-second lazyload" data-src="{{ product.featured_image.src | img_url: '1024x' }}" alt="{{ product.featured_image.src.alt }}">
                                </noscript>
                                <img class="product__thumbnail lazyload"
                                  src="data:image/svg+xml,%3Csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 7 10'%3E%3C/svg%3E"
                                  data-src="{{ img_url }}"
                                  data-widths="[360, 540, 720, 900, 1080, 1296, 1512, 1728, 1944, 2048, 4472]"
                                  data-aspectratio="{{ product.featured_image.aspect_ratio }}"
                                  data-sizes="auto"
                                  alt="{{ product.featured_image.alt }}" 
                                  data-image>
                                {% for image in product.images %}
                                  {% assign img_second = image.src | img_url: '1x1' | replace: '_1x1.', '_{width}x.' %}
                                  {% if forloop.first != true %}
                                    <img id="{{ img_id }}"
                                      class="img-fluid product__thumbnail-second lazyload"
                                      src="data:image/svg+xml,%3Csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 7 10'%3E%3C/svg%3E"
                                      data-src="{{ img_second }}"
                                      data-widths="[180, 360, 540, 720, 900, 1080, 1296, 1512, 1728, 2048]"
                                      data-aspectratio="{{ image.aspect_ratio }}"
                                      data-sizes="auto"
                                      alt="{{ image.src.alt }}"
                                      data-image>
                                    {% break %}
                                  {% endif %}
                                {% endfor %}
                              </div>
                            </a>
                            {% include 'group_buttons' %}
                              <div class="badge">
                                {% if product.compare_at_price > product.price %}
                                  <div class="badge_sale">
                                  </div>
                                {% endif %}
                              </div>                     
                            <div class="badge_sale-old"></div>                          
                          </div>
                          <div class="product__info">
                            <div class="block_product_info">
                              <div class="cate">
                                {% for collection in product.collections %}
                                  {% if forloop.first == true %}
                                    <a href="{{ collection.url }}" title="{{ collection.title }}">{{ collection.title }}</a>
                                  {% endif %}
                                {% endfor %}
                              </div>
                              <div class="product__title">
                                <a href="{{ product.url }}">{{ product.title }}</a>
                              </div>
                              {% if settings.show_rating %}
                                <div class="product__review">
                                {% render 'judgeme_widgets'
                                  , widget_type: 'judgeme_preview_badge'
                                  , jm_style: ''
                                  , concierge_install: true
                                  , product: product %}
                                </div>
                              {% endif %}
                              <div class="product__price{% if settings.show_rating == false %} pb-20{% endif %}">
                                {% include 'product-price' %}
                              </div>
                              {% if product.variants.size > 0 %}
                                {% if settings.show_variant_color %}
                                  <div class="selectorVariants {% if product.variants.size > 0 %} has-border{% endif %}">
                                    {% include 'nov-swatch-color' with 'Color' %}
                                  </div>
                                {% endif %}
                              {% endif %}
                              {% unless product.available %}
                                <div class="available_product d-flex">
                                  <span class="product__available sold-out mt-15">
                                    <i class="zmdi zmdi-alert-octagon"></i>
                                    <span>{{ "products.product.sold_out" | t }}</span>
                                  </span>
                                </div>
                              {% else %}
                                <div class="available_product d-flex">
                                  <span class="product__available in-stock mt-15">
                                    <i class="fa fa-check-square-o" aria-hidden="true"></i>
                                    <span>{{ "products.product.in_stock" | t }}</span>
                                  </span>
                                </div>
                              {% endunless %}
                              <div class="desc mt-15">{{ product.description | strip_html | truncate: 230 }}</div>
                            </div>
                          </div>
                        </div>
                      </div>

                    {%- endfor -%}
                  </div>
                  
                  {%- if paginate.pages > 1 -%}
                    <div class="nov-pagination d-flex align-items-center {{ paginate.part }}">{% render 'pagination', paginate: paginate, anchor: '', class: '' %}</div>
                  {%- endif -%}              
                {%- endif -%}
              {%- endpaginate -%}
            </div>
          </div>
        </div>
      </div>
    {% if viewtype == 'leftsidebar' or viewtype == 'rightsidebar' %}
    </div>
    {% endif %}
    {% if viewtype != 'full_width' %}
    </div>
    {% endif %}
    {% comment %}
    {% include 'collection-filters-mobile' %}
    {% endcomment %}

    <script src="{{ 'collection-filters-form.js' | asset_url }}" defer="defer"></script>
  </div>
</div>
{% schema %}
  {
    "name": "Collection pages",
    "settings": [
      {
        "type": "image_picker",
        "id": "banner",
        "label": "Banner"
      },
      {
        "type": "range",
        "id": "products_per_page",
        "min": 4,
        "max": 30,
        "step": 1,
        "label": "Products per page",
        "default": 12,
        "info": "Select number products per page"
      },
      {
        "type": "checkbox",
        "id": "sort_enable",
        "label": "Enable sorting",
        "default": true
      },
      {
        "type": "checkbox",
        "id": "show_tags",
        "label": "Show tags",
        "default": true
      }
    ]
  }
{% endschema %}
{% if viewtype == 'full_width' %}
  <style>
    .template-collection #NovBreadcrumbs {
      padding-bottom: 126px !important;
    }
    @media (max-width: 1199px) {
      .template-collection #NovBreadcrumbs {padding-bottom: 90px !important;}
    }
    @media (max-width: 991px) {
      .template-collection #NovBreadcrumbs {padding-bottom: 90px !important;}
    }
    @media (max-width: 767px) {
      .template-collection #NovBreadcrumbs {padding-bottom: 55px !important;}
    }
  </style>
{% endif %}
<script>
const endlessCollection = new Ajaxinate({
container: '#product-grid',
pagination: '.infinite_next',
});
</script>
<script>
setTimeout(function () {
  var filters = document.querySelectorAll('.js-filter');
  filters.forEach(function(filter) {
      var dataIndex = filter.getAttribute('data-index');
      console.log(dataIndex);
      if (dataIndex == "4") {
          var facetsLabel = filter.querySelector('.facets__label');
          console.log('test');
          if (facetsLabel) {
            facetsLabel.click();
          }
      }
  });                     
}, 1000);


setTimeout(function () {
  updatesorting();
}, 2000);

$('#FacetFiltersForm').on('click', 'input', function(){
  console.log('qwert');
   setTimeout(function () {
      updatesorting();
   }, 1500);
});

function updatesorting(){
  var $elements = $('.js-filter');
  var $filteredElements = $elements.filter(function() {
    return $(this).data('index') === 4;
  });
  if ($filteredElements.length > 0) {
      $filteredElements.each(function() {
        console.log('TEst');
        var $list = $(this).find('ul');
        var $items = $list.children('li').get();
        $items.sort(function(a, b) {
            var keyA = $(a).find('span').text().toLowerCase();
            var keyB = $(b).find('span').text().toLowerCase();
            if (keyA < keyB) return -1;
            if (keyA > keyB) return 1;
            return 0;
        });
        $.each($items, function(i, li) {
            $list.append(li);
        });
    });
  } else {
    console.log('No element with data-index=4 found');
  }
}

setTimeout(function () {
   var selectsort = $('.sort-by__label').text();
  if(selectsort == 'Best selling'){
    $('.sort-by__label').text('Top Sellers');
  }
}, 1000);
$("#ProductGridContainer").find('.product--item').each(function(){
    var geturl = $(this).find('a').attr('href');
    const url = geturl.split('?')[0];
    $(this).find('a').attr('href', url);
});
</script>