{%- assign new_comment = false -%}
{% if comment and comment.created_at %}
  {%- assign new_comment = true -%}
  {%- assign new_comment_id = comment.id -%}
{% endif %}
{% if new_comment %}
  {%- assign duplicate_comment = false %}
  {% for comment in article.comments %}
    {% if comment.id == new_comment_id %}
      {%- assign duplicate_comment = true %}
      {% break %}
    {% endif %}
  {% endfor %}

  {% if duplicate_comment %}
    {%- assign number_of_comments = article.comments_count -%}
  {% else %}
    {%- assign number_of_comments = article.comments_count | plus: 1 -%}
  {% endif %}
{% else %}
  {%- assign number_of_comments = article.comments_count -%}
{% endif %}

{% if template == "article.leftsidebar" %}
  {% assign viewtype = "article_left" %}
{% elsif template == "article.rightsidebar" %}
  {% assign viewtype = 'article_right' %}
{% elsif template == "article.nosidebar" %}
  {% assign viewtype = 'article_without' %}
{% else %}
  {% if settings.type_sidebar_article == 'article_leftsidebar' %}
    {% assign viewtype = 'article_left' %}
  {% elsif settings.type_sidebar_article == 'article_rightsidebar' %}
    {% assign viewtype = 'article_right' %}
  {% elsif settings.type_sidebar_article == 'article_without' %}
    {% assign viewtype = 'article_without' %}
  {% endif %}
{% endif %}


<div class="{% if viewtype == 'article_left' %}left_sidebar{% elsif viewtype == 'article_right' %}right_sidebar{% else viewtype == 'article_without' %}no_sidebar{% endif %}">
  {% include 'nov-breadcrumb' %}
  <article class="page-width nov-template-article mt-150 mt-xs-70 {% if viewtype == 'article_left' %}left_sidebar{% elsif viewtype == 'article_right' %}right_sidebar{% else viewtype == 'article_without' %}no_sidebar{% endif %}" itemscope itemtype="http://schema.org/Article">
    {% if viewtype != 'article_without' %}
      <div class="container_1320">
    {% else %}
      <div class="container_1320">
    {% endif %}
      <div class="row{% if viewtype != 'article_without' %} spacing-60{% endif %}">
        {% if viewtype != 'article_without' %}
          <div class="sidebar sidebar-article col-lg-3 col-md-4{% if viewtype == 'article_right' %} flex-last{% endif %}">
            {% include 'nov-blog-sidebar' %}
          </div>
        {% endif %}
          <div class="{% if viewtype != 'article_without' %}col-lg-9 col-md-8 blog_detail mt-xs-30{% else %}col-lg-12 col-md-12 blog_detail mt-xs-30{% endif %}">
            <div class="post">
              {% if section.settings.blog_show_image_feature %}
              <div class="article__thumnail">
                <div class="respone_image" style="padding-top:{{ 1 | divided_by: article.image.aspect_ratio | times: 100}}%;">
                  {% assign img_url = article.image | img_url: '1x1' | replace: '_1x1.', '_{width}x.' %}
                  <img class="article__list-image lazyload"
                    src="data:image/svg+xml,%3Csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 1 1'%3E%3C/svg%3E"
                    data-src="{{ img_url }}"
                    data-widths="[360, 540, 720, 900, 1080, 1296, 1512, 1728, 1944, 2048]"
                    data-aspectratio="{{ article.image.aspect_ratio }}"
                    data-sizes="auto"
                    alt="">
                </div>
              </div>
              {% endif %}
              <div class="article__title">{{ article.title }}</div>
            </div>
            <div class="rte" itemprop="articleBody">
              {{ article.content }}
            </div>
            <div class="article__info d-flex align-items-center">
              <div class="blog_cs">
                {% if section.settings.blog_show_date %}
                  <span class="article__date">
                    <i class="zmdi zmdi-calendar-note"></i>{{ article.published_at | time_tag: format: 'month_day_year' }}
                  </span>
                {% endif %}
                {% if section.settings.blog_show_author %}
                  <span class="article__author"><i class="zmdi zmdi-account"></i>{{ 'blogs.article.by_author' | t: author: article.author }}</span>
                {% endif %}
                {% if blog.comments_enabled? %}
                  <span class="article__countcomment"><i class="zmdi zmdi-comment-alt"></i>{{ 'blogs.comments.comments_with_count' | t: count: article.comments_count }}</span>
                {% endif %}
              </div>
              <div class="blog_share">
                {% if section.settings.show_share_buttons %}
                  <div class="article__share btn-group">
                    <a class="dropdown-toggle" href="#" id="dropdownsharebutton" data-toggle="dropdown" aria-haspopup="true" aria-expanded="false">
                      <i class="zmdi zmdi-share"></i><span>{{ 'blogs.article.share' | t }}</span>
                    </a>
                    <div class="dropdown-menu" aria-labelledby="dropdownsharebutton">
                      {% include 'social-sharing', share_title: article.title, share_permalink: article.url, share_image: article.image %}
                    </div>
                  </div>
                {% endif %}
                <div class="article__print">
                  <a href="javascript:window.print()"><i class="zmdi zmdi-print"></i><span>{{ 'blogs.article.print' | t }}</span></a>
                </div>
              </div>
            </div>

            {% include 'nov-blog-related' %}

            {% if blog.comments_enabled? %}
              {% if number_of_comments > 0 %}
              <div class="article__comments">
                <div class="title-block text-uppercase text-center">{{ 'blogs.comments.comments_with_count' | t: count: number_of_comments }}</div>
                {% paginate article.comments by 5 %}
                  <div id="comments">
                    {% if new_comment %}
                      <p class="note form-success">
                        {% if blog.moderated? %}
                          {{ 'blogs.comments.success_moderated' | t }}
                        {% else %}
                          {{ 'blogs.comments.success' | t }}
                        {% endif %}
                      </p>
                    {% endif %}
                    <ul class="comments">
                      {% if new_comment %}
                        <li id="{{ comment.id }}" class="comment">
                          {% include 'comment' %}
                        </li>
                      {% endif %}
                      {% for comment in article.comments %}
                        {% unless comment.id == new_comment_id %}
                          <li id="{{ comment.id }}" class="comment">
                            {% include 'comment' %}
                          </li>
                        {% endunless %}
                      {% endfor %}
                    </ul>
                    {% if paginate.pages > 1 %}
                      {% include 'pagination' %}
                    {% endif %}
                  </div>
                {% endpaginate %}
              </div>
              {% endif %}
              <div>
                <div class="comment-form form-vertical">
                  {% form 'new_comment', article %}
                    <div class="title_block mb-60">{{ 'blogs.comments.title' | t }}</div>
                    {{ form.errors | default_errors }}
                    <div>
                      <div class="row">
                        <div class="col col-xs-12">
                          <input type="text" name="comment[author]" id="CommentAuthor" placeholder="{{ 'blogs.comments.name' | t }} (*)" class="input-full{% if form.errors contains 'author' %} input--error{% endif %}" value="{{ form.author }}" required>
                        </div>
                        <div class="col col-xs-12">
                          <input type="email" name="comment[email]" id="CommentEmail" placeholder="{{ 'blogs.comments.email' | t }} (*)" class="input-full{% if form.errors contains 'email' %} input--error{% endif %}" value="{{ form.email }}" required>
                        </div>
                        <div class="col col-xs-12">
                          <input type="tel" name="comment[phone]" id="CommentPhone" placeholder="{{ 'blogs.comments.phone' | t }} (*)" class="input-full{% if form.errors contains 'phone' %} input--error{% endif %}" value="{{ form.phone }}">
                        </div>
                      </div>
                      <div>
                        <textarea rows="10" cols="50" name="comment[body]" id="CommentBody" placeholder="{{ 'blogs.comments.message' | t }}" class="input-full{% if form.errors contains 'body' %} input--error{% endif %}" required>{{ form.body }}</textarea>
                      </div>
                    </div>
                    <button type="submit" value="Submit" class="hover_x btn btn-send" >
                      <span>{{ 'blogs.comments.post' | t }}</span>
                      <i class="zmdi zmdi-long-arrow-right"></i>
                    </button>
                  {% endform %}
                </div>
              </div>
            {% endif %}
          </div>
      </div>
    </div>
  </article>
</div>

{% schema %}
  {
    "name": "Posts",
    "settings": [
      {
        "type": "checkbox",
        "id": "blog_show_image_feature",
        "label": "Show Image Feature",
        "default": true
      },
      {
        "type": "checkbox",
        "id": "blog_show_author",
        "label": "Show author",
        "default": true
      },
      {
        "type": "checkbox",
        "id": "blog_show_date",
        "label": "Show date",
        "default": true
      },
      {
        "type": "checkbox",
        "id": "show_share_buttons",
        "label": "Show social sharing buttons",
        "default": true
      }
    ],
    "blocks": [
      {
        "type": "block_categories",
        "name": "Categories Product",
        "settings": [
          {
            "type": "text",
            "id": "sidebar_categories_title",
            "label": "Title",
            "default": "Categories"
          },
          {
            "type": "link_list",
            "id": "sidebar_categories_menu",
            "label": "Choose Menu",
            "info": "Choose menu for block. Add new menu: Admin -> Navigation"
          },
          {
            "type": "text",
            "id": "class",
            "label": "Class"
          }
        ]
      },
      {
        "type": "block_search",
        "name": "Block Search",
        "settings": [
          {
            "type": "text",
            "id": "class",
            "label": "Class"
          }
        ]
      },
      {
        "type": "block_html",
        "name": "Block HTML",
        "settings": [
          {
            "type": "text",
            "id": "block_title",
            "label": "Title"
          },
          {
            "type": "textarea",
            "id": "html_content",
            "label": "Content",
            "placeholder": "You can input code html for content.",
            "info": "You can input code html for content."
          },
          {
            "type": "text",
            "id": "class",
            "label": "Class"
          }
        ]
      },
      {
        "type": "block_recentpost",
        "name": "Block Recent Post",
        "settings": [
          {
            "type": "text",
            "id": "block_title",
            "label": "Title",
            "default": "Recent post"
          },
          {
            "type": "range",
            "id": "number_show",
            "min": 2,
            "max": 10,
            "step": 1,
            "label": "Number Show",
            "default": 2,
            "info": "Select number post show"
          },
          {
            "type": "checkbox",
            "id": "show_date",
            "label": "Show date",
            "default": true
          },
          {
            "type": "checkbox",
            "id": "show_comment",
            "label": "Show Comment",
            "default": true
          },
          {
            "type": "checkbox",
            "id": "show_author",
            "label": "Show Author",
            "default": false
          },
          {
            "type": "checkbox",
            "id": "show_excerpt",
            "label": "Show Excerpt",
            "default": false
          },
          {
            "type": "checkbox",
            "id": "show_more",
            "label": "Show More",
            "default": false
          },
          {
            "type": "text",
            "id": "class",
            "label": "Class"
          }
        ]
      },
      {
        "type": "block_producttags",
        "name": "Block Product Tags",
        "settings": [
          {
            "type": "text",
            "id": "block_title",
            "label": "Title",
            "default": "Product Tags"
          },
          {
            "type": "range",
            "id": "number_show",
            "min": 2,
            "max": 20,
            "step": 1,
            "label": "Number Show",
            "default": 2,
            "info": "Select number tags show"
          },
          {
            "type": "text",
            "id": "class",
            "label": "Class"
          }
        ]
      },
      {
        "type": "block_blogtags",
        "name": "Block Blog Tags",
        "settings": [
          {
            "type": "text",
            "id": "block_title",
            "label": "Title",
            "default": "Blog Tags"
          },
          {
            "type": "range",
            "id": "number_show",
            "min": 2,
            "max": 20,
            "step": 1,
            "label": "Number Show",
            "default": 2,
            "info": "Select number tags show"
          },
          {
            "type": "text",
            "id": "class",
            "label": "Class"
          }
        ]
      },
      {
        "type": "block_banner",
        "name": "Block Banner",
        "settings": [
          {
            "type": "text",
            "id": "banner_title",
            "label": "Title"
          },
          {
            "type": "image_picker",
            "id": "banner_image",
            "label": "Banner image"
          },
          {
            "type": "text",
            "id": "title",
            "label": "Text image"
          },
          {
            "type": "text",
            "id": "t_link",
            "label": "Text link"
          },
          {
            "type": "url",
            "id": "banner_link",
            "label": "Banner link"
          },
          {
            "type": "text",
            "id": "class",
            "label": "Class"
          }
        ]
      }
    ]
  }
{% endschema %}
