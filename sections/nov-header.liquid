<script>
  document.addEventListener('DOMContentLoaded', function () {
    const popup = document.querySelector('.popup-wrap');
    const closeBtn = document.querySelector('.btn-close');

    if (!popup || !closeBtn) {
      console.error('Popup elements not found in DOM');
      return;
    }

    // --- Frequency Capping Check ---
    const HAS_SEEN_POPUP = localStorage.getItem('popupDisplayed');

    // Set your popup open and close dates (Melbourne/AEDT: UTC+11:00)
    const openDate = new Date('2025-12-03T23:59:00+11:00');
    const closeDate = new Date('2025-12-25T23:59:00+11:00');
    const now = new Date();

    // Check if current date is within the range AND the user hasn't seen it before
    if (now >= openDate && now <= closeDate && !HAS_SEEN_POPUP) {
      // 1. Show the popup
      popup.style.display = 'block';

      // 2. Set the localStorage flag so it doesn't show up again
      localStorage.setItem('popupDisplayed', 'true');
    } else {
      // Hide if outside range OR if the flag is set
      popup.style.display = 'none';
    }

    // Close popup on click (This is just an extra way to close it)
    closeBtn.addEventListener('click', function () {
      popup.style.display = 'none';
      // NOTE: The flag is already set above, so we don't need to set it again here.
    });
  });
</script>

