{%- assign logo_tabbar = section.settings.logo_tabbar -%}
<div data-section-id="{{ section.id }}" data-section-type="header-section">
  <header
    class="site-header {% if section.settings.stickymenu == true %}sticky-menu{% endif %}"
    {% if section.settings.background_color != blank and template.name == 'index' %}
      style="background-color: {{ section.settings.background_color }};"
    {% endif -%}
    {% if section.settings.background_color_inner != blank and template.name != 'index' %}
      style="background-color: {{ section.settings.background_color_inner }};"
    {% endif %}
  >
    {% if section.settings.announcement_on_off and section.settings.announcement != blank %}
      <div class="header-top" style="background-color: {{ section.settings.announcement_bg }}">
        <div class="container_90">
          <div class="row align-items-center">
            {% if section.settings.social %}
              <div class="col-md-3 d-none d-md-block">{% include 'nov-social' %}</div>
            {% endif %}
            <div class="{% if section.settings.social %}col-lg-6 col-md-9{% else %}col-12{% endif %}">
              {% if section.settings.announcement != blank %}
                <div
                  class="announcement text-center text-md-right text-lg-center pt-15 pb-15"
                  style="color: {{ section.settings.announcement_c }};"
                >
                  {{ section.settings.announcement }}
                </div>
              {% endif %}
            </div>
          </div>
        </div>
      </div>
    {% endif %}
    <div class="header-mobile d-xl-none" style="background-color: {{ section.settings.background_color_mobile }};">
      <div class="d-flex align-items-center">
        <div class="mobile_logo text-center">
          {% if section.settings.logo_mobile %}
            <a href="/" class="site-header__logo-image" style="display: block;z-index: 9;" aria-label="ESNC Perfumery">
              <img
                class="lazypreload lazyloaded"
                src="{{ section.settings.logo_mobile | img_url: '500x' }}"
                alt="ESNC Perfumery"
                style="max-width: {{ section.settings.width_lg_mb }}px!important;"
              >
            </a>
          {% else %}
            <a class="site-header__logo-link" href="/" itemprop="url">{{ shop.name }}</a>
          {% endif %}
        </div>

        <div id="mobile_search">
          {% include 'nov-formsearch-inline' %}
        </div>

        <div class="d-flex justify-content-end">
          <div id="show-megamenu" class="item-mobile-top">
            <i class="zmdi zmdi-view-headline" style="color: {{ section.settings.color_mobile }};"></i>
          </div>
        </div>
      </div>
    </div>
    <div class="container_90">
      <div class="header-center d-none d-xl-block">
        <div class="row d-flex align-items-center" style="position: relative;">
          <div class="col-md-6 col-xl-4 order-2 order-xl-1">
            <div class="search-bar">
              <form action="/search" method="get" class="search-header-inline search" role="search">
                <div class="search-container-inner">
                  <input
                    class="search-header__input"
                    id="predictive-search-input"
                    type="search"
                    name="q"
                    placeholder="Notes, Scent family, Style, Code"
                    aria-label="Search"
                    autocomplete="off"
                  >
                  <button class="search-header__submit text-center btn--link" type="submit" aria-label="Search">
                    <span class="site-header__search-icon">
                      <i class="zmdi zmdi-search"></i>
                    </span>
                  </button>
                </div>
              </form>
            </div>
          </div>
          <div class="contentsticky_logo col-md-3 col-xl-4 text-center order-1 order-xl-2">
            <div class="h2 site-header__logo m-0" itemscope itemtype="http://schema.org/Organization">
              {% if section.settings.logo %}
                <a href="/" itemprop="url" class="site-header__logo-image" aria-label="ESNC Perfumery">
                  <img
                    class="lazypreload lazyloaded"
                    src="{{ section.settings.logo | img_url: '500x' }}"
                    alt="ESNC Perfumery"
                    style="max-width: {{ section.settings.width_lg }}px!important;"
                  >
                </a>
              {% else %}
                <a class="site-header__logo-link" href="/" itemprop="url">{{ shop.name }}</a>
              {% endif %}
            </div>
            <p class="hdtext">INSPIRED BY THE ONES YOU LOVE</p>
          </div>
          <div class="nav2 storelocator col-md-3 col-xl-4 text-right order-1 order-xl-2">
            <a href="/pages/locations">Store Locator</a>
          </div>
          <!-- ===================== CSS ===================== -->
          <!-- Live Search Results Dropdown -->
          <div
            id="predictive-search-results"
            style="
              display: block;
              position: absolute;
              top: 80px;
              left: 0px;
              right: 0px;
              border-top: none;
              z-index: 9999;
              border-radius: 8px;
              overflow: hidden;
              width: calc(100% - 40px);
              margin: 0 auto;
            "
          >
            <div class="predictive-header-block"></div>
          </div>

          <style>
            #predictive-search-results {
              box-shadow: rgba(0, 0, 0, 0.13) 0px 4px 16px;
            }
            .predictive-item img {
                max-height: 90px;
                max-width: 70px;
            }
            .predictive-group {
              overflow: hidden;
              max-height: 475px;
              background: #ffff;
              position: relative;
            }
            .predictive-items {
              gap: 20px;
              padding: 5px 20px 20px;
              width: 100%;
              margin: 0 auto;
            }
            .predictive-items .predictive-item {
              width: calc(20% - 16px);
              padding: 10px;
              border-radius: 5px;
              border: 1px solid #8080804a;
              gap: 10px;
              display: flex;
            }
            .predictive-item-info {
              display: flex;
              flex-direction: column;
              width: 100%;
              gap: 5px;
            }
            .predictive-item-title {
              font-size: 14px;
              line-height: normal;
              color: #000 !important;
              font-weight: 500 !important;
            }
            .predictive-item-price {
              font-size: 20px;
              font-weight: 600;
              color: #000;
              line-height: 22px;
              margin-right: 20px;
              font-family: -apple-system, BlinkMacSystemFont, Segoe UI, Roboto, Helvetica Neue, Arial, sans-serif,
                'Apple Color Emoji', 'Segoe UI Emoji', Segoe UI Symbol, 'Noto Color Emoji';
            }
            .predictive-header {
              color: var(--color-heading);
              font-size: 2.8rem;
              font-weight: 700;
              line-height: 35px;
              text-transform: capitalize;
              font-family: var(--font-family-default);
              padding: 0 20px;
              border-bottom: 1px solid;
              margin: 10px 0;
              padding-bottom: 10px;
              display: flex;
              align-items: center;
              justify-content: space-between;
            }
            .predictive-header svg {
              cursor: pointer;
              position: absolute;
              top: 17px;
              right: 20px;
            }
            .predictive-view-all {
              padding: 10px 40px;
              margin: 0 auto;
              width: fit-content;
              display: flex;
              height: 50px;
              line-height: 50px;
              background: #2abab0;
              position: relative;
              border-radius: 100px;
              align-items: center;
              color: #fff;
            }
            .predictive-view-all:hover {
              background: #000;
              color: #ffff;
            }
            .predictive-no-results {
              background: #fff;
              border-radius: 8px;
              padding: 10px;
              min-height: 200px;
              display: flex;
              justify-content: center;
              align-items: center;
            }
            .predictive-view-all-wrapper {
              background-color: #fff;
              border-radius: 0 0 8px 8px;
              padding: 10px 0;
            }
            #mobile-predictive-search-results {
              border-radius: 8px !important;
              overflow: hidden !important;
              top: 50px !important;
            }

            /* ===== LOADING ===== */
            .predictive-loading {
              background: #fff;
              border-radius: 8px;
              padding: 10px;
              min-height: 200px;
              display: flex;
              flex-direction: column;
              justify-content: center;
              align-items: center;
              gap: 14px;
            }
            .predictive-spinner {
              width: 42px;
              height: 42px;
              border: 4px solid #e0e0e0;
              border-top-color: #2abab0;
              border-radius: 50%;
              animation: predictive-spin 0.75s linear infinite;
            }
            .predictive-loading-text {
              font-size: 14px;
              color: #555;
              font-family: -apple-system, BlinkMacSystemFont, Segoe UI, Roboto, Helvetica Neue, Arial, sans-serif;
            }
            @keyframes predictive-spin {
              to {
                transform: rotate(360deg);
              }
            }
            /* ===== END LOADING ===== */
            @media screen and (max-width: 1440px) {
              .predictive-items .predictive-item {
                 width: calc(25% - 15px);
              }
            }
            @media screen and (max-width: 1140px) {
              .predictive-items .predictive-item {
                width: calc(33.33% - 13.33px);
              }
            }
            @media screen and (max-width: 991px) {
              .predictive-items .predictive-item {
                width: calc(33.33% - 13.33px);
              }
              .predictive-item-title {
                font-size: 12px;
              }
              .predictive-item-price {
                  font-size: 18px;
              }
              .predictive-item img {
    max-height: 55px;
    max-width: 60px;
}
            }
            @media screen and (max-width: 767px) {
              .predictive-items .predictive-item {
                width: calc(50% - 10px);
              }
              .predictive-group {
                max-height: 60vh;
              }
              
            }
            @media screen and (max-width: 575px) {
              .predictive-items {
                gap: 15px;
              }
              #mobile-predictive-search-results {
                top: 100px !important;
                left: 10px !important;
                width: calc(100% - 20px) !important;
                right: 10px !important;
                position: fixed !important;
              }
              .predictive-item-title {
                font-size: 12px;
              }
            }
              @media screen and (max-width: 500px) {
              .predictive-items .predictive-item {
                width: calc(100% - 10px);
              }
            }
          </style>
          <!-- ===================== JAVASCRIPT ===================== -->
<script>
(function () {
    function initPredictiveSearch(inputId, resultsId) {
      const input = document.getElementById(inputId);
      if (!input) return;

      let resultsBox = document.getElementById(resultsId);
      if (!resultsBox) {
        resultsBox = document.createElement('div');
        resultsBox.id = resultsId;
        resultsBox.className = 'predictive-search-results';
        resultsBox.style.cssText =
          'display:none; position:absolute; z-index:9999; width:100%; left:0; top:100%; background:#fff; box-shadow:0 4px 16px rgba(0,0,0,0.13); border-radius:0 0 8px 8px;';
        const parent = input.closest('form') || input.parentElement;
        parent.style.position = 'relative';
        parent.appendChild(resultsBox);
      }

      function setBodyScroll(lock) {
        if (inputId === 'mobile-predictive-search-input') {
          document.body.style.overflow = lock ? 'hidden' : '';
        }
      }

      let debounceTimer;
      let lastQuery = '';
      let currentPage = 1;
      let totalCount = 0;
      let isFetching = false;
      let hasMore = true;
      let itemsWrapper = null;
      let abortController = null;

      input.addEventListener('input', function () {
        const query = this.value.trim();
        clearTimeout(debounceTimer);
        if (query.length < 3) {
          hideResults();
          return;
        }
        if (query === lastQuery) return;
        showLoading();
        debounceTimer = setTimeout(() => {
          lastQuery = query;
          currentPage = 1;
          hasMore = true;
          isFetching = false;
          if (abortController) abortController.abort();
          fetchResults(query, 1, true);
        }, 350);
      });

      input.addEventListener('focus', function () {
        const query = this.value.trim();
        if (query.length >= 3) {
          if (resultsBox.innerHTML !== '') {
            resultsBox.style.display = 'block';
            setBodyScroll(true);
          } else {
            showLoading();
            lastQuery = query;
            currentPage = 1;
            hasMore = true;
            isFetching = false;
            if (abortController) abortController.abort();
            fetchResults(query, 1, true);
          }
        }
      });

      function fetchResults(query, page, reset) {
        if (isFetching || !hasMore) return;
        isFetching = true;

        abortController = new AbortController();
        const signal = abortController.signal;

        const searchUrl = '/search?q=' + encodeURIComponent(query) + '&type=product&page=' + page;

        fetch(searchUrl, { signal })
          .then((res) => res.text())
          .then((html) => {
            if (query !== lastQuery) {
              isFetching = false;
              return;
            }

            const parser = new DOMParser();
            const doc = parser.parseFromString(html, 'text/html');

            if (page === 1) {
              const allText = doc.body.innerText || doc.body.textContent || '';
              const match = allText.match(/(\d+)\s+results?\s+for/i);
              if (match) totalCount = parseInt(match[1]);
            }

            const productCards = doc.querySelectorAll('.search_product_grid_item');
            const products = [];

            productCards.forEach((card) => {
              const imgEl = card.querySelector('img');
              const linkEl = card.querySelector('a');
              const priceEl =
                card.querySelector('[class*="price"]') ||
                card.querySelector('[class*="Price"]') ||
                card.querySelector('.money') ||
                card.querySelector('[class*="money"]');

              const title = imgEl ? (imgEl.getAttribute('alt') || '').trim() : '';
              const url = linkEl ? (linkEl.getAttribute('href') || '') : '';
              const image = imgEl
                ? (imgEl.getAttribute('data-src') || imgEl.getAttribute('src') || '')
                : '';
              const price = priceEl ? priceEl.textContent.trim() : '';

              if (!title || !url) return;
              products.push({ title, url, image, price });
            });

            if (page === 1 && products.length === 0) {
              fetchFallback(query);
              return;
            }

            if (products.length === 0) {
              hasMore = false;
              removeLoadingSpinner();
              isFetching = false;
              return;
            }

            const nextPageLink =
              doc.querySelector('a[href*="page=' + (page + 1) + '"]') ||
              doc.querySelector('.pagination__next') ||
              doc.querySelector('[aria-label="Next"]') ||
              doc.querySelector('.next a');

            if (!nextPageLink) hasMore = false;

            renderResults(products, query, reset);
            isFetching = false;
          })
          .catch((err) => {
            if (err.name === 'AbortError') {
              isFetching = false;
              return;
            }
            if (query !== lastQuery) {
              isFetching = false;
              return;
            }
            if (page === 1) fetchFallback(query);
            else isFetching = false;
          });
      }

      function fetchFallback(query) {
        const url =
          '/search/suggest.json?q=' +
          encodeURIComponent(query) +
          '&resources[type]=product' +
          '&resources[options][fields]=title,product_type,variants.title,tag,body';

        fetch(url)
          .then((res) => res.json())
          .then((data) => {
            if (query !== lastQuery) {
              isFetching = false;
              return;
            }
            const products =
              (data.resources && data.resources.results && data.resources.results.products) || [];
            const mapped = products.map((p) => ({
              title: p.title,
              url: p.url,
              image:
                p.featured_image && p.featured_image.url
                  ? p.featured_image.url.replace(/(\.[a-z]+)(\?.*)?$/, '_500x500$1')
                  : '',
              price: p.price ? '$' + Number(p.price).toFixed(2) : ''
            }));
            totalCount = mapped.length;
            hasMore = false;
            renderResults(mapped, query, true);
            isFetching = false;
          })
          .catch(() => {
            resultsBox.innerHTML =
              '<div class="predictive-no-results">Something went wrong.</div>';
            resultsBox.style.display = 'block';
            isFetching = false;
          });
      }

      function renderResults(products, query, reset) {
        if (reset) {
          resultsBox.innerHTML = '';

          const groupWrapper = document.createElement('div');
          groupWrapper.className = 'predictive-group';

          const header = document.createElement('div');
          header.className = 'predictive-header';
          header.innerHTML = `
            <span>Products</span>
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
              <path fill-rule="evenodd" clip-rule="evenodd"
                d="M5.29289 5.29289C5.68342 4.90237 6.31658 4.90237 6.70711 5.29289L12 10.5858L17.2929 5.29289C17.6834 4.90237 18.3166 4.90237 18.7071 5.29289C19.0976 5.68342 19.0976 6.31658 18.7071 6.70711L13.4142 12L18.7071 17.2929C19.0976 17.6834 19.0976 18.3166 18.7071 18.7071C18.3166 19.0976 17.6834 19.0976 17.2929 18.7071L12 13.4142L6.70711 18.7071C6.31658 19.0976 5.68342 19.0976 5.29289 18.7071C4.90237 18.3166 4.90237 17.6834 5.29289 17.2929L10.5858 12L5.29289 6.70711C4.90237 6.31658 4.90237 5.68342 5.29289 5.29289Z"
                fill="#0F1729"/>
            </svg>
          `;
          groupWrapper.appendChild(header);

          const closeBtn = header.querySelector('svg');
          closeBtn.addEventListener('click', (e) => {
            e.stopPropagation();
            hideResults();
            input.blur();
          });

          itemsWrapper = document.createElement('div');
          itemsWrapper.className = 'predictive-items row grid grid--view-items';
          itemsWrapper.style.cssText = 'max-height: calc(420px - 100px); overflow-y:auto;';
          groupWrapper.appendChild(itemsWrapper);

          resultsBox.appendChild(groupWrapper);

          const viewAllWrapper = document.createElement('div');
          viewAllWrapper.className = 'predictive-view-all-wrapper';
          const viewAll = document.createElement('a');
          viewAll.href = '/search?q=' + encodeURIComponent(query) + '&type=product';
          viewAll.className = 'predictive-view-all';
          viewAll.textContent = 'View all';
          viewAllWrapper.appendChild(viewAll);
          resultsBox.appendChild(viewAllWrapper);

          itemsWrapper.addEventListener('scroll', () => {
            const nearBottom =
              itemsWrapper.scrollTop + itemsWrapper.clientHeight >=
              itemsWrapper.scrollHeight - 80;
            if (nearBottom && !isFetching && hasMore) {
              currentPage++;
              addLoadingSpinner();
              fetchResults(lastQuery, currentPage, false);
            }
          });
        }

        removeLoadingSpinner();

        products.forEach((product) => {
          const a = document.createElement('a');
          a.href = product.url;
          a.className = 'predictive-item';

          const imgSrc = product.image || 'https://placehold.co/52x52?text=No+Image';

          const priceHtml = product.price
            ? '<span class="predictive-item-price">' + escHtml(product.price) + '</span>'
            : '';

          a.innerHTML =
            '<img src="' +
            escAttr(imgSrc) +
            '" alt="' +
            escAttr(product.title) +
            '" loading="lazy">' +
            '<div class="predictive-item-info">' +
            '<span class="predictive-item-title">' +
            highlightMatch(product.title, query) +
            '</span>' +
            priceHtml +
            '</div>';

          itemsWrapper.appendChild(a);
        });

        resultsBox.style.display = 'block';
        setBodyScroll(true);
      }

      function addLoadingSpinner() {
        if (!itemsWrapper) return;
        const spinner = document.createElement('div');
        spinner.className = 'predictive-loading predictive-scroll-spinner';
        spinner.style.cssText = 'display:flex; justify-content:center; align-items:center; width:100%; padding:12px 0;';
        spinner.innerHTML = `<div class="predictive-spinner"></div><span class="predictive-loading-text">Loading…</span>`;
        itemsWrapper.appendChild(spinner);
      }

      function removeLoadingSpinner() {
        if (!itemsWrapper) return;
        const spinner = itemsWrapper.querySelector('.predictive-scroll-spinner');
        if (spinner) spinner.remove();
      }

      function showLoading() {
        resultsBox.innerHTML = `
          <div class="predictive-loading">
            <div class="predictive-spinner"></div>
            <span class="predictive-loading-text">Searching…</span>
          </div>
        `;
        resultsBox.style.display = 'block';
        setBodyScroll(true);
      }

      function hideResults() {
        if (abortController) {
          abortController.abort();
          abortController = null;
        }
        resultsBox.style.display = 'none';
        resultsBox.innerHTML = '';
        lastQuery = '';
        currentPage = 1;
        hasMore = true;
        isFetching = false;
        itemsWrapper = null;
        setBodyScroll(false);
      }

      function highlightMatch(text, query) {
        const escaped = query.replace(/[.*+?^${}()|[\]\\]/g, '\\$&');
        const regex = new RegExp('(' + escaped + ')', 'gi');
        return escHtml(text).replace(
          regex,
          '<mark style="background:#fff3b0;padding:0 2px;border-radius:2px;">$1</mark>'
        );
      }

      function escHtml(str) {
        return String(str)
          .replace(/&/g, '&amp;')
          .replace(/</g, '&lt;')
          .replace(/>/g, '&gt;')
          .replace(/"/g, '&quot;');
      }

      function escAttr(str) {
        return String(str).replace(/"/g, '&quot;');
      }

      document.addEventListener('click', (e) => {
        if (!input.contains(e.target) && !resultsBox.contains(e.target)) {
          hideResults();
        }
      });

      input.addEventListener('keydown', (e) => {
        if (e.key === 'Escape') {
          hideResults();
          input.blur();
        }
      });
    }

    initPredictiveSearch('predictive-search-input', 'predictive-search-results');
    initPredictiveSearch('mobile-predictive-search-input', 'mobile-predictive-search-results');
  })();
</script>
