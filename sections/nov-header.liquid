          <div class="contentsticky_menu col-md-3 col-xl-12 mt-lg-4 order-3 order-xl-4" id="contentsticky_menu">
            <div class="header-social text-center">
              {% include 'nov-social' %}
            </div>
            <div class="menu-nav-wrapper">
              <div class="vertical_dropdown justify-content-end d-xl-none">
                <i class="zmdi zmdi-sort-amount-desc"></i>
              </div>
              <nav id="AccessibleNav" class="ver_menu text-center">
                {% include 'site-nav' %}
              </nav>
            </div>
            <div class="contentsticky_item d-none order-3 d-xl-flex justify-content-end align-items-center content_right">
              {% if settings.wishlist_enable %}
                <div class="site_wishlist pt-3">
                  <a href="/pages/wishlist" class="d-flex align-items-center" aria-label="View Wishlist">
                    <i class="icon-wishlist"></i>
                  </a>
                </div>
              {% endif %}
              {% if settings.mini_cart_type == 'canvas' %}
                <div class="cart_canvas">
                  <div
                    class="open_header_cart_canvas d-none d-md-flex"
                    data-img-cart="{{ settings.img_nocart | img_url: '200x'}}"
                  ></div>
                  <div id="cart_block">
                    <div class="header-cart d-flex align-items-center">
                      <div class="site-header__cart pt-3">
                        <span class="icon-cart"></span>
                      </div>
                      <span id="_desktop_cart_count" class="site-header__cart-count">
                        <span id="CartCount">{{ cart.item_count }}</span>
                      </span>
                    </div>
                  </div>
                </div>
              {% else %}
                <div class="cart_dropdown">
                  <div id="cart_block">
                    <div class="header-cart d-flex align-items-center">
                      <div class="site-header__cart">
                        <span class="icon-cart"></span>
                      </div>
                      <span id="_desktop_cart_count" class="site-header__cart-count">
                        <span id="CartCount">{{ cart.item_count }}</span>
                      </span>
                    </div>
                    <div id="_desktop_cart"><div id="cart-info"></div></div>
                  </div>
                </div>
              {% endif %}
              {% if shop.customer_accounts_enabled %}
                {% if customer %}
                  <div class="user_account">
                    <a
                      class="myaccount"
