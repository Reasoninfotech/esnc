{{ 'swiper-bundle.min.css' | asset_url | stylesheet_tag }}
<script src="{{ 'swiper-bundle.min.js' | asset_url }}" defer="defer"></script>
{%- if section.blocks.size > 0 -%}
    {{ 'section-marquee.css' | asset_url | stylesheet_tag }}
    {%- liquid
        assign padding_top = section.settings.padding_top
        assign padding_bottom = section.settings.padding_bottom
        assign icon = section.settings.icon
        assign limitItems = 12 | divided_by: section.blocks.size
    -%}
 <div class="swiper mySwiper text-swiper-container">
     <div class="swiper-wrapper">
        <div class="swiper-slide">Free Shipping over $99</div>
        <div class="swiper-slide">Try before you buy: 13 retail outlets across Victoria and NSW</div>
        <div class="swiper-slide">Over 120+ Perfumes</div>
        <div class="swiper-slide">Australian owned, Shipped from Melbourne</div>
        <div class="swiper-slide">Made in Turkiye with French oils</div>
        <div class="swiper-slide">No Nasty Ingredients</div>
        <div class="swiper-slide">No Celebrity Endorsements</div>
        <div class="swiper-slide">No Big-brand Logos</div>
        <div class="swiper-slide">Fair prices</div>
        <div class="swiper-slide">No Added Markups : Same great quality</div>
     </div>
</div>
    <script>
    window.addEventListener('load', (event) => {
        var options = {
            "slidesPerView":"auto",
            "grabCursor":true,
            "speed":10000,
            "spaceBetween":50,
            "freeMode":true,
            "loop":true,
            "centeredSlides":true,
            "autoplay":{
                "delay":0,
                "disableOnInteraction":false
            }
        }
        let slider = new Swiper ('.text-swiper-container', options);
    });
</script>
{%- endif -%}
{% schema %}
    {
        "name": "Marque",
        "max_blocks": 50,
        "tag": "section",
        "class": "section",
        "settings": [
            {
                "type": "color",
                "id": "mq_background",
                "label": "Background Color"
            },
            {
                "type": "color_background",
                "id": "mq_gradient",
                "label": "Background Gradient"
            },
            {
                "type": "range",
                "id": "text_size",
                "label": "Text Font Size",
                "min": 10,
                "max": 60,
                "step": 1,
                "unit": "px",
                "default": 40
            },
            {
                "type": "range",
                "id": "gap_blocks",
                "label": "Gap Blocks",
                "min": 0,
                "max": 100,
                "step": 1,
                "unit": "px",
                "default": 20
            },
            {
                "type": "select",
                "id": "border",
                "label": "Border",
                "default": "none",
                "options": [
                    {
                        "value": "none",
                        "label": "None"
                    },
                    {
                        "value": "top",
                        "label": "Top"
                    },
                    {
                        "value": "bottom",
                        "label": "Bottom"
                    },
                    {
                        "value": "top_bottom",
                        "label": "Top & Bottom"
                    }
                ]
            },
            {
                "type": "color",
                "id": "border_color",
                "default": "#000000",
                "label": "Border Color"
            },
            {
                "type": "select",
                "id": "icon",
                "label": "Icon",
                "default": "thunder",
                "options": [
                    {
                        "value": "none",
                        "label": "None"
                    },
                    {
                        "value": "thunder",
                        "label": "Thunder"
                    },
                    {
                        "value": "fire",
                        "label": "Fire"
                    }
                ]
            },
            {
                "type": "color",
                "id": "icon_color",
                "default": "#000000",
                "label": "Icon color"
            },
            {
                "type": "header",
                "content": "Mobile"
            },
            {
                "type": "range",
                "id": "text_size_mb",
                "label": "Text Font Size Mobile",
                "min": 10,
                "max": 60,
                "step": 1,
                "unit": "px",
                "default": 30
            },
            {
                "type": "color",
                "id": "border_color_mb",
                "default": "#000000",
                "label": "Border Color Mobile"
            },
            {
                "type": "color",
                "id": "icon_color_mb",
                "default": "#000000",
                "label": "Icon color mobile"
            },
            {
                "type": "header",
                "content": "Spacing"
            },
            {
                "type": "range",
                "id": "padding_top",
                "min": 0,
                "max": 100,
                "step": 1,
                "unit": "px",
                "label": "Spacing Top",
                "default": 20
            },
            {
                "type": "range",
                "id": "padding_bottom",
                "min": 0,
                "max": 100,
                "step": 1,
                "unit": "px",
                "label": "Spacing Bottom",
                "default": 20
            },
            {
                "type": "range",
                "id": "minus_spacing_top",
                "label": "Minus Spacing Top",
                "default": 0,
                "min": -200,
                "max": 0,
                "step": 2,
                "unit": "t:sections.layout.mg_desktop.unit",
                "info": "(This settings only use for Desktop)"
            }
        ],
        "blocks": [
            {
                "type": "marquee",
                "name": "Marque",
                "settings": [
                    {
                        "type": "richtext",
                        "id": "text",
                        "label": "Text",
                        "default": "<p>Welcome to our store</p>"
                    },
                    {
                        "type": "color",
                        "id": "color",
                        "default": "#000000",
                        "label": "Color"
                    },
                    {
                        "type": "color",
                        "id": "color_mb",
                        "default": "#000000",
                        "label": "Color Mobile"
                    }
                ]
            }
        ],
        "presets": [
            {
                "name": "Marque",
                "blocks": [
                    {
                        "type": "marquee"
                    }
                ]
            }
        ]
    }
{% endschema %}