<div class="distance{% if section.settings.class_section != blank %} {{ section.settings.class_section }}{% endif %}">
  {% if section.settings.has_fullwidth == false %}
  <div class="container">
  {% endif %}
    {% if section.settings.title != blank %}
      <div class="title_block text-uppercase {{ section.settings.title_alignment }}" style="{% if block.settings.color_title != blank %}color: {{ block.settings.color_title }};{% endif %}{% if block.settings.size_title != blank %}font-size: {{ block.settings.size_title }};{% endif %}">{{ section.settings.title }}</div>
    {% endif %}
    <div class="row spacing-{{ section.settings.spacing }} collection-text-row">
      {% case section.blocks.size %}
        {% when 1 %}
          {%- assign column_size = 'col-lg-12 col-md-12' -%}
        {% when 2 %}
          {%- assign column_size = 'col-lg-6 col-md-6' -%}
        {% when 3 %}
          {%- assign column_size = 'col-lg-4 col-md-4' -%}
        {% when 4 %}
          {%- assign column_size = 'col-lg-3 col-md-6 mb-md-20' -%}
        {% when 5 %}
          {%- assign column_size = 'col-lg-cus-5 col-md-cus-5' -%}
        {% else %}
          {%- assign column_size = 'col-lg-2 col-md-4' -%}
      {% endcase %}

      {% for block in section.blocks %}
        <a href="{{ block.settings.link }}" 
           class="gallery-main-wrapper {{ column_size }} gallery-image_column{% if block.settings.class != blank %} {{ block.settings.class }}{% endif %}" 
           aria-label="{{ block.settings.cta_label | escape }}">
          <div class="image-wrapper">
            {% if block.settings.backgroundimage != blank %}
              {% assign img_url1 = block.settings.backgroundimage | img_url: '1x1' | replace: '_1x1.', '.' %}
              <picture>
                <source 
                  srcset="{{ block.settings.backgroundimage | img_url: '540x' }} 540w" 
                  media="(min-width: 768px)">
                <source 
                  srcset="{{ block.settings.backgroundimage | img_url: '270x' }} 270w" 
                  media="(max-width: 767px)">
                <img 
                  class="onHoverImage lazyload"
                  src="{{ block.settings.backgroundimage | img_url: '270x' }}"
                  alt="{{ block.settings.image.alt | escape }}" 
                  height="270" 
                  width="270" 
                  loading="lazy"
                  fetchpriority="high"
                  style="height: auto; width: auto;">
              </picture>
            {% endif %}
            {% if block.settings.image != blank %}
              {% assign img_url = block.settings.image | img_url: '1x1' | replace: '_1x1.', '.' %}
              <picture>
                <source 
                  srcset="{{ block.settings.image | img_url: '540x' }} 540w" 
                  media="(min-width: 768px)">
                <source 
                  srcset="{{ block.settings.image | img_url: '270x' }} 270w" 
                  media="(max-width: 767px)">
                <img 
                  class="normalImage lazyload"
                  src="{{ block.settings.image | img_url: '270x' }}"
                  data-src="{{ img_url }}"
                  alt="{{ block.settings.image.alt | escape }}" 
                  height="270" 
                  width="270" 
                  fetchpriority="high"
                  loading="lazy"
                  style="height: auto; width: auto;">
              </picture>
            {% else %}
              <img 
                src="https://via.placeholder.com/640x360" 
                alt="Placeholder Image" 
                height="270" 
                width="270" 
                style="height: auto; width: auto;">
            {% endif %}
          </div>
          <div class="collection-text-wrapper">
            {% if block.settings.cta_label != blank %}               
              <span>{{ block.settings.cta_label | escape }}</span>
            {% endif %}
            {% if block.settings.cta_label2 != blank %}
              <p class="caption2">{{ block.settings.cta_label2 }}</p>
            {% endif %}
            {% if block.settings.link != blank %}
              <span class="product-grid-items">Shop Now</span>
            {% endif %}
          </div>
        </a>
      {% endfor %}

    </div>
  {% if section.settings.has_fullwidth == false %}
  </div>
  {% endif %}
</div>
{% if section.blocks.size == 0 %}
  {% include 'no-blocks' %}
{% endif %}

{% schema %}
  {
    "name": "Vinova Gallery Image New",
    "class": "index-section section-gallery-image",
    "max_blocks": 6,
    "settings": [
      {
        "type": "text",
        "id": "title",
        "label": "Heading",
        "default": "Vinova Gallery Image"
      },
      {
        "type": "text",
        "id": "size_title",
        "label": "Size Title",
        "default": "14px"
      },
      {
        "type": "color",
        "id": "color_title",
        "label": "Color Title",
        "default": "#222"
      },
      {
        "type": "select",
        "id": "title_alignment",
        "label": "Heading alignment",
        "default": "text-left",
        "options": [
          {
            "value": "text-left",
            "label": "Left"
          },
          {
            "value": "text-center",
            "label": "Center"
          },
          {
            "value": "text-right",
            "label": "Right"
          }
        ]
      },
      {
        "type": "select",
        "id": "spacing",
        "label": "Spacing Items",
        "default": "0",
        "options": [
          {
            "label": "0px",
            "value": "0"
          },
          {
            "label": "5px",
            "value": "5"
          },
          {
            "label": "10px",
            "value": "10"
          },
          {
            "label": "15px",
            "value": "15"
          },
          {
            "label": "20px",
            "value": "20"
          },
          {
            "label": "25px",
            "value": "25"
          },
          {
            "label": "30px",
            "value": "30"
          },
          {
            "label": "40px",
            "value": "40"
          },
          {
            "label": "50px",
            "value": "50"
          },
          {
            "label": "60px",
            "value": "60"
          }
        ]
      },
      {
        "type": "checkbox",
        "id": "has_fullwidth",
        "label": "Full Width",
        "default":   false
      },
      {
        "type": "color",
        "id": "background_color",
        "label": "Background colors"
      },
      {
        "type": "text",
        "id": "class_section",
        "label": "Class"
      },
      {
        "type": "text",
        "id": "distance_top",
        "label": "Top Distance Section",
        "default": "30px"
      },
      {
        "type": "text",
        "id": "distance_bottom",
        "label": "Bottom Distance Section",
        "default": "30px"
      }
    ],
    "blocks": [
      {
        "type": "image",
        "name": "Image",
        "settings": [
          {
            "type": "image_picker",
            "id": "image",
            "label": "Image"
          },
          {
            "type": "image_picker",
            "id": "backgroundimage",
            "label": "Hover Image"
          },
          {
            "type": "text",
            "id": "cta_label",
            "label": "Caption"
          },
          {
            "type": "text",
            "id": "cta_label2",
            "label": "Caption 2"
          },
          {
            "type": "text",
            "id": "size_link",
            "label": "Size Link",
            "default": "12px"
          },
          {
            "type": "color",
            "id": "color_link",
            "label": "Color Link",
            "default": "#000"
          },
          {
            "type": "url",
            "id": "link",
            "label": "Link",
            "info": "Optional"
          },
          {
            "type": "color",
            "id": "background_button",
            "label": "Background Button",
            "default": "#fff"
          },
          {
            "type": "text",
            "id": "class",
            "label": "Class"
          }
        ]
      }
    ],
    "presets": [
      {
        "name": "Vinova Gallery Image New",
        "category": "Image",
        "blocks": [
          {
            "type": "image"
          },
          {
            "type": "image"
          }
        ]
      }
    ]
  }
{% endschema %}

<style>
  #shopify-section-{{ section.id }} .distance {
    padding-top: {{ section.settings.distance_top }};
    padding-bottom: {{ section.settings.distance_bottom }};
  }
</style>