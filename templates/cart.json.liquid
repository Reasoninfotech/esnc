{% layout none %}
<form action="/cart" method="post" class="cart ajaxcart leidsens">
  <div class="ajaxcart__inner">
    {% for item in cart.items %}
      <div class="ajaxcart__product" data-line="{{ forloop.index }}">
        <div class="media">
          <a href="{{ item.url }}">
            <img class="d-flex product-image" src="{{ item | img_url: '100x100' }}" alt="{{ item.product.title }}" title="{{ item.product.title }}">
          </a>
          <div class="media-body">
            <a class="product-name" href="{{ item.url }}">
              <span class="title">{{ item.product.title }}</span>
              <span class="bt_s">
                {% unless item.variant.title contains 'Default' %}
                {% assign p_option = '' %}
                {% for option in item.product.options %}
                  {% if p_option == '' %}
                    {% assign p_option = item.variant.options[forloop.index0] %}
                  {% else %}
                    {% assign p_option = '/ ' | append: item.variant.options[forloop.index0] %}
                  {% endif %}
                  {{ p_option }}
                {% endfor %}
                {% endunless %}
              </span>

            </a>
            <div class="mb-5">
              {%- assign property_size = item.properties | size -%}
              {% if property_size > 0 %}
              <span class="ajaxcart__product-meta">
                {% for p in item.properties %}
                  {% unless p.last == blank %}
                    {{ p.first }}:

                    {% if p.last contains '/uploads/' %}
                    	<a href="{{ p.last }}">{{ p.last | split: '/' | last }}</a>
                    {% else %}
                    {{ p.last }}
                    {% endif %}
                  {% endunless %}
                {% endfor %}
              </span>
              {% endif %}
           	</div>

            <span class="product-price"> 
              {% if item.original_line_price != item.line_price %}
              <small class="ajaxcart-item__price-strikethrough"><s>{{ item.original_line_price | money }}</s></small>
              <br><span class="money">
<span class='revy-cart-line-item-price' data-product-id='{{item.product_id}}' data-variant-id='{{item.variant_id}}' data-key='{{item.key}}'>

<span class='revy-cart-line-item-price' data-product-id='{{item.product_id}}' data-variant-id='{{item.variant_id}}' data-key='{{item.key}}'>
{{ item.line_price | money }}
</span>

</span>
</span>
              {% else %}
              <span class="money">
<span class='revy-cart-line-item-price' data-product-id='{{item.product_id}}' data-variant-id='{{item.variant_id}}' data-key='{{item.key}}'>

<span class='revy-cart-line-item-price' data-product-id='{{item.product_id}}' data-variant-id='{{item.variant_id}}' data-key='{{item.key}}'>
{{ item.line_price | money }}
</span>

</span>
</span>
              {% endif %}
            </span>
            <span class="quantity"> x {{ item.quantity }}</span>

            <a class="remove-from-cart" rel="nofollow" href="javascript:void(0);" title="remove from cart" data-line="{{ forloop.index }}" data-product-id={{ item.id }}>
              <i class="fa fa-trash-o" aria-hidden="true"></i>
            </a>
          </div>
        </div>
      </div>
    {% endfor %}
  </div>

  {%- liquid
      assign freeshipping_value         = settings.free_shipping | plus: 0
      assign spend_value  = freeshipping_value | times: 100 | money
      assign price_without_currency     = cart.total_price | money_without_currency
      unless "EUR INR ANG ARS BRL BYN BYR CLF CLP COP CRC CZK DKK EUR HRK HUF IDR ISK MZN NOK PLN RON RUB SEK TRY UYU VES VND" contains shop.currency
        assign price                    = price_without_currency | replace: ',' | plus: 0
      else
        assign price                    = price_without_currency | replace: '.' | plus: 0
      endunless
    -%}
  {% if price < freeshipping_value %}
    <div id="threshold_bar_popup_minicart"{% if settings.freeshipping_enable == false %} class="d-none"{% endif %}>
      <div class="cart_threshold">
        <div class="threshold_spend">{{ 'cart.general.spend_html' | t: spend: spend_value }}</div>
        <div class="threshold_bar">
          <span class="animate" style="width:{{ price | times: 100 | divided_by: freeshipping_value | round: 0 }}%!important">
            <span>{{ price | times: 100 | divided_by: freeshipping_value | round: 0 }}%</span>
          </span>
        </div>
      </div>
  </div>
  {% else %}
    <div id="threshold_bar_popup_minicart"{% if settings.freeshipping_enable == false %} class="d-none"{% endif %}>
      <div class="threshold_spend spend_congrats"><span>{{ 'cart.general.content_threshold' | t }}<i class="rbb-icon-delivery-11"></i></span></div>
      <div class="threshold_bar threshold_congrats"><span class="animate" style="width: 100% !important;"><span>100%</span></span></div>
    </div>
  {% endif %}

  <div class="ajaxcart__footer">
    <div class="subtotal d-flex align-items-center justify-content-between">
      <label>{{ 'cart.general.total' | t }}&nbsp;:</label>
      <span class="money">{{ cart.total_price | money }}</span>
    </div>
    {% if cart.total_discount > 0 %}
    <div class="total d-flex align-items-center">
      <label>{{ 'cart.general.total' | t }}&nbsp;:</label>
      <span class="money">{{ cart.total_discount | money }}</span>
    </div>
    {% endif %}
    <div class="cart-bottom">
    <ul class="sales_points newul">
      <li class="sales_point">
        <span class="icon-and-text">
          <img src="https://5203b3-0b.myshopify.com/cdn/shop/files/21-05-2024_4-00-10_PM_220x.jpg" alt="Vegan-friendly certification badge">
          <span>Vegan Friendly</span>
        </span>
      </li>  
      <li class="sales_point">
        <span class="icon-and-text">
          <img src="https://5203b3-0b.myshopify.com/cdn/shop/files/21-05-2024_4-01-45_PM_220x.jpg" alt="Cruelty-Free certification badge">           
          <span>Cruelty Free</span>
        </span>
        </li>
      <li class="sales_point">
        <span class="icon-and-text">
            <img src="https://5203b3-0b.myshopify.com/cdn/shop/files/21-05-2024_4-06-37_PM_220x.jpg" alt="Susta-inable certification badge">            
          <span>Sustainable</span>
        </span>
        </li>
      <li class="sales_point">
        <span class="icon-and-text">
            <img src="https://5203b3-0b.myshopify.com/cdn/shop/files/21-05-2024_4-09-00_PM_220x.jpg" alt="Paraben-Free certification badge">
            Paraben Free
        </span>
      </li>
    </ul>
  </div>
    <div class="d-flex justify-content-center flex-column-reverse">
      <a href="/cart" class="hover_x btn">
        <span>{{ 'cart.general.view_cart' | t }}</span>
        <i class="zmdi zmdi-long-arrow-right"></i>
      </a>
      <button type="submit" class="hover_x btn cart__checkout" name="checkout">
        <span>{{ 'cart.general.checkout' | t }}</span>
        <i class="zmdi zmdi-long-arrow-right"></i>
      </button>
    </div>
  </div>
</form>
