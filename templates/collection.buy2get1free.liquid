    <script>
       const productsPerPage = 500;
       function fetchProducts(page, filterTag, selectClass, collectionHandle, excludeCollectionHandle) {

      const fetchCollectionProducts = (collection, page) =>
          $.ajax({
              url: `/collections/${collection}/products.json`,
              data: {
                  limit: productsPerPage,
                  page: page
              },
              dataType: 'json'
          });
  
      // Fetch products from both collections
      $.when(fetchCollectionProducts(collectionHandle, page), fetchCollectionProducts(excludeCollectionHandle, 1))
          .done(function (productresponse, freeproductresponse) {
              const allProducts = productresponse[0].products;
              const freeProducts = freeproductresponse[0].products;
  
              // Log the raw data for debugging
              console.log("All Products:", allProducts);
              console.log("Free Products:", freeProducts);
  
              // Get IDs of products in the Free Niche collection
              const freeNicheProductIds = new Set(freeProducts.map(product => product.id));
  
              // Filter out Free-Niche products from Niche products
              let filteredProducts = allProducts.filter(product => !freeNicheProductIds.has(product.id));
  
              // Log the filtered products before applying the tag filter
              console.log("Filtered Products (Excluding Free products):", filteredProducts);
  
              // Apply the tag filter if provided
              if (filterTag) {
                  filteredProducts = filteredProducts.filter(product => product.tags.includes(filterTag));
              }
  
              // Log the filtered products after applying the tag filter
              console.log("Filtered Products (After Applying Tag Filter):", filteredProducts);
  
              // Sort products by title
              const sortedProducts = filteredProducts.sort((a, b) => a.title.localeCompare(b.title));
  
              // Populate the product dropdown
              const productsContainer = $('.' + selectClass);
              productsContainer.empty();
              let productElement = '<option value="">-- Select a Product --</option>';
              sortedProducts.forEach(product => {
                  const hasAvailableVariant = product.variants.some(variant => variant.available);
                  if (hasAvailableVariant) {
                      productElement += `<option value="${product.variants[0].id}">${product.title}</option>`;
                  }
              });
              productsContainer.append(productElement);
  
              // Handle pagination
              const paginationContainer = $('#pagination');
              paginationContainer.empty();
              const totalPages = Math.ceil(productresponse[0].products_count / productsPerPage);
              if (totalPages > 1) {
                  if (page > 1) {
                      paginationContainer.append(`<a href="#" onclick="fetchProducts(${page - 1}, '${filterTag}', '${selectClass}', '${collectionHandle}', '${excludeCollectionHandle}'); return false;">Previous</a>`);
                  }
                  for (let i = 1; i <= totalPages; i++) {
                      if (i === page) {
                          paginationContainer.append(`<span>${i}</span>`);
                      } else {
                          paginationContainer.append(`<a href="#" onclick="fetchProducts(${i}, '${filterTag}', '${selectClass}', '${collectionHandle}', '${excludeCollectionHandle}'); return false;">${i}</a>`);
                      }
                  }
                  if (page < totalPages) {
                      paginationContainer.append(`<a href="#" onclick="fetchProducts(${page + 1}, '${filterTag}', '${selectClass}', '${collectionHandle}', '${excludeCollectionHandle}'); return false;">Next</a>`);
                  }
              }
          })
          .fail(function () {
              console.error("Failed to fetch products from one or both collections.");
          });
  }
  
        var gender = "";
        const queryString = new URL(window.location.href).searchParams.get('q');
        const queryStringgender = new URL(window.location.href).searchParams.get('g');
        if(queryStringgender){
          if(queryStringgender == 'male'){
               gender = 'Male';
          }else if(queryStringgender == 'female'){
            gender = 'Female';
          }
        }
        if(queryString){
          var collectionHandle = queryString;
          var freecollection = 'free-niche';
          if(collectionHandle == 'selective'){
            $('.selectiveimage').show();
            var collectionHandle = 'selective';
                freecollection = 'free-selective';
          }else{
            $('.nicheimage').show();
            var collectionHandle = 'Niche';
            freecollection = 'free-niche';
          }
        }else{
          var collectionHandle = 'Niche';
          freecollection = 'free-niche';
          $('.nicheimage').show();
        }


        if(gender == 'Male'){
          fetchProducts(1, 'Male', 'buyhim', collectionHandle, freecollection);
        }else if(gender == 'Female'){
          fetchProducts(1, 'Female', 'buyhim', collectionHandle, freecollection);
        }else{
          fetchProducts(1, '', 'buyhim', collectionHandle, freecollection);
        }
      
        if(gender == 'Male'){
          fetchProducts(1, 'Male', 'buyher', collectionHandle, freecollection);
        }else if(gender == 'Female'){
          fetchProducts(1, 'Female', 'buyher', collectionHandle, freecollection);
        }else{
          fetchProducts(1, '', 'buyher', collectionHandle, freecollection);
        }

        if(gender == 'Male'){
          fetchProducts(1, 'Male', 'buyfree', freecollection, 'no');
        }else if(gender == 'Female'){
          fetchProducts(1, 'Female', 'buyfree', freecollection, 'no');
        }else{
          fetchProducts(1, '', 'buyfree', freecollection, 'no');
        }
      
        /*fetchProducts(1, 'Male', 'buyhim', collectionHandle, freecollection);
        fetchProducts(1, 'Female', 'buyher', collectionHandle, freecollection);
        fetchProducts(1, '', 'buyfree', freecollection, 'no');*/
    </script>
    
    <script>
      document.getElementById('buy-now-button').addEventListener('click', function () {
          const buyhim = document.getElementById('buyhim').value;
          const buyher = document.getElementById('buyher').value;
          const buyfree = document.getElementById('buyfree').value;
          $('.form-error').hide();
          if (!buyhim || !buyher || !buyfree) {
            $('.form-error').show();
            return false;
          }
          const cartItems = [
            { id: parseInt(buyhim), quantity: 1 },
            { id: parseInt(buyher), quantity: 1 },
            { id: parseInt(buyfree), quantity: 1 },
          ];
          fetch('/cart/add.js', {
            method: 'POST',
            headers: {
              'Content-Type': 'application/json',
            },
            body: JSON.stringify({ items: cartItems }),
          })
            .then(response => {
              if (response.ok) {
                /*window.location.href = '/cart';*/
              } else {
                return response.json().then(errorData => {
                  console.error('Error details:', errorData);
                  alert('Failed to add items to cart. Please check your selections.');
                });
              }
            })
            .catch(error => console.error('Error:', error));
      });
    </script>
